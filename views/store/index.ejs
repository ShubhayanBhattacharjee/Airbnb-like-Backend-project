<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <!-- hero section -->
  <div class="hero-frame">
    <section class="hero">
      <div class="hero-bg">
        <img src="/images/hero2.png" alt="Luxury Farmhouse">
      </div>
      <div class="hero-body">
        <span class="hero-eyebrow">Slow Travel · Real Connection</span>
        <h1 class="hero-title">
          <span class="line-1">Where calm</span>
          <span class="line-2">meets <em>luxury.</em></span>
        </h1>
        <p class="hero-sub">Not a place to escape life, but to return to it.</p>
        <a href="/explore" class="hero-cta" id="heroCta">
          <span class="cta-label">Discover Stays</span>
          <span class="cta-icon">→</span>
        </a>
      </div>
      <div class="hero-live-badge">
        <span class="live-dot"></span>
        <span><span class="live-count" id="liveCount">23</span> people exploring stays right now</span>
      </div>
      <div class="hero-signals">
        <div class="signal-card">
          <span class="signal-icon">🌿</span>
          <div>
            <strong>Off-grid</strong>
            <span>by choice</span>
          </div>
        </div>
        <div class="signal-card">
          <span class="signal-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M2 8C6 4 18 4 22 8" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 12C8 9 16 9 19 12" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8.5 16C10.5 14.5 13.5 14.5 15.5 16" stroke="currentColor" stroke-width="1.5"/>
              <line x1="3" y1="3" x2="21" y2="21" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </span>
          <div>
            <strong>Disconnect</strong>
            <span>to reconnect</span>
          </div>
        </div>
        <div class="signal-card">
          <span class="signal-icon">🌲</span>
          <div>
            <strong>Curated stays</strong>
            <span>in nature</span>
          </div>
        </div>
      </div>
      <div class="hero-ambience">
        18°C · Pinewood Retreat
      </div>
      <div class="scroll-indicator">
        <div class="scroll-mouse">
          <div class="scroll-dot"></div>
        </div>
        <span class="scroll-text">SCROLL TO DISCOVER</span>
      </div>
      <div class="hero-dock">
        <div class="hero-socials">
          <a href="#">🐦</a>
          <a href="#">🌐</a>
          <a href="#">in</a>
        </div>
      </div>
      <!-- <div class="hero-brand">HomeStays</div> -->
    </section>
  </div>

  <!-- philosophy section -->
  <section class="philosophy-section">
    <div class="philosophy-label">
      OUR PHILOSOPHY
    </div>
    <h2 class="philosophy-text">
      <span class="center-line">
        Travel should not pull 
      </span>
      <strong>you away from life.</strong> The right stay slows everything down —
      giving you space to <strong>reconnect with nature</strong>,
      with people, and with yourself.
    </h2>
    <div class="world-inner">
      <div class="world-label">
        OUR WORLD OF STAYS
      </div>
      <div class="world-content">
        <div class="world-map-area">
          <img
            src="/images/explore_world.png"
            alt="World Map"
            class="world-map">
          <svg class="travel-path" viewBox="0 0 1000 500" preserveAspectRatio="none">
            <!-- canada -> poland -->
            <path
              id="line1"
              class="travel-line"
              d="M190 160 C350 90, 470 120, 590 170"
            />
            <!-- poland -> australia -->
            <path
              id="line2"
              class="travel-line"
              d="M590 170 C760 240, 820 330, 860 420"
            />
            <!-- argentina -> canada -->
            <path
              id="line3"
              class="travel-line"
              d="M310 390 C180 330, 120 250, 190 160"
            />
            <!-- australia -> argentina -->
            <path
              id="line4"
              class="travel-line"
              d="M860 420 C720 470, 500 470, 310 390"
            />
          </svg>
          <div class="map-pin pin-1" id="pin1">
            <div class="pin-dot"></div>
            <div class="pin-card">
              <img src="/images/stay1.png">
              <div>
                <strong>Forest Cabin</strong>
                <span>Canada</span>
                <small>48.4284° N, 1.3656° W</small>
              </div>
            </div>
          </div>
          <div class="map-pin pin-2" id="pin2">
            <div class="pin-dot"></div>
            <div class="pin-card">
              <img src="/images/stay2.png">
              <div>
                <strong>Snow Home</strong>
                <span>Poland</span>
                <small>4.4284° N, 1.3656° W</small>
              </div>
            </div>
          </div>
          <div class="map-pin pin-3" id="pin3">
            <div class="pin-dot"></div>
            <div class="pin-card">
              <img src="/images/stay3.png">
              <div>
                <strong>Cliff House</strong>
                <span>Argentina</span>
                <small>37.7179° N, 8.5981° W</small>
              </div>
            </div>
          </div>
          <div class="map-pin pin-4" id="pin4">
            <div class="pin-dot"></div>
            <div class="pin-card">
              <img src="/images/stay4.png">
              <div>
                <strong>Beach Calm</strong>
                <span>Australia</span>
                <small>8.4095° S, 115.1889° E</small>
              </div>
            </div>
          </div>
        </div>
        <div class="world-copy">
          <h2>
            Discover stays
            shaped by
            <em>nature, silence,</em>
            and <em>slower living</em>.
          </h2>
          <p>
            Handpicked homes across forests,
            coastlines, mountains, and hidden
            landscapes around the world. All available with HomeStays and We're with you.
          </p>
          <a href="/explore" class="explore-btn">
            <span>EXPLORE STAYS</span>
            <div class="btn-arrow">
              →
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- listing section -->
  <main class="stays-showcase-section" id="listings">
    <div class="showcase-heading">
      <div>
        <span class="section-tag">HANDPICKED STAYS</span>
        <h2>Stay close to what <em>matters.</em></h2>
        <p>Thoughfully chosen homes in the world's most peaceful places.<br>Each stay is unique, just like the journey you're on.</p>
      </div>
      <!-- <a href="/host/addHome" class="add-home-btn">
        + Add Your Home
      </a> -->
    </div>
    <div class="showcase-layout">
      <aside class="showcase-sidebar">
        <div class="sidebar-links">
          <a href="#listings" class="sidebar-item active">
            <span>🍃 All Stays</span>
            <small><%= registeredHomes.length %></small>
          </a>
          <% 
            const fallbackCategories = [
              { name: "Nature", icon: "🌲" },
              { name: "Water", icon: "🌊" },
              { name: "Mountains", icon: "⛰" },
              { name: "Remote", icon: "🏕" }
            ];
            const categoriesToRender = 
              (typeof categories !== "undefined" && categories.length)
              ? categories
              : fallbackCategories;
          %>
          <% categoriesToRender.forEach(category => { %>
            <a 
              href="#listings" 
              class="sidebar-item">
              <span>
                <%= category.icon || "🍂" %>
                <%= category.name %>
              </span>
              <small>
                <%= category.count || Math.floor(Math.random() * 20) + 4 %>
              </small>
            </a>
          <% }) %>
        </div>
        <div class="sidebar-note">
          <span>🍂 SLOWER LIVING</span>
          <p>
            Spaces that invite you to slow down
            and reconnect with yourself.
          </p>
        </div>
      </aside>
      <div class="stays-grid">
        <% registeredHomes.slice(0,8).forEach(home => { %>
        <a href="/" class="stay-card-link">
          <div class="stay-card">
            <div class="card-image-wrap">
              <img src="<%= home.photo %>" alt="<%= home.houseName %>">
              <button class="wishlist-btn">♡</button>
            </div>
            <div class="stay-overlay">
              <div class="stay-location">
                <%= home.location %>
              </div>
              <h3 class="stay-title">
                <%= home.houseName %>
              </h3>
              <div class="stay-meta">
                <p class="stay-price">
                  ₹<%= home.price %>
                  <span>/ night</span>
                </p>
                <div class="stay-rating">
                  <span class="rating-star">★</span> 4.9
                </div>
              </div>
            </div>
          </div>
        </a>
        <% }) %>
      </div>
      <div class="discover-more-wrap">
        <a href="/explore" class="discover-more-btn">
          <span>DISCOVER MORE</span>
          <div class="discover-arrow">→</div>
        </a>
      </div>
    </div>
  </main>

  <section class="cinematic-section">
    <!-- <div class="cinematic-top">
      <span class="cinematic-label">
        THE EXPERIENCE
      </span>
      <h2 class="cinematic-title">
        The best stays
        change your <em>pace.</em>
      </h2>
      <p class="cinematic-copy">
        Not designed to impress for a moment,
        but to stay with you long after you leave.
      </p>
    </div> -->
    <div class="cinematic-frame" id="cinematicFrame">
      <video
        id="experienceVideo"
        class="cinematic-video"
        autoplay
        muted
        loop
        playsinline>
        <source src="/videos/experience.mp4" type="video/mp4">
      </video>
      <div class="cinematic-overlay">
        <div class="overlay-top">
          <span>Slow Living</span>
          <span>Nature • Silence • Design</span>
        </div>
        <div class="overlay-center">
          <h3>
            Wake slowly.<br>
            Stay longer.
          </h3>
        </div>
        <div class="overlay-bottom">
          <button class="sound-btn" id="soundBtn">
            Enable Sound
          </button>
          <button class="fullscreen-btn" id="fullscreenBtn">
            Full Experience ↗
          </button>
        </div>
      </div>
    </div>
  </section>

  <section class="testimonials-section">
    <div class="testimonials-top">
      <span class="testimonials-label">
        GUEST EXPERIENCES
      </span>
      <h2>
        What people <em>feel</em>
        after staying
      </h2>
      <p>
        Real experiences from guests who found
        more than just a place to stay.
      </p>
    </div>
    <div class="testimonial-slider">
      <div class="testimonial-track">
        <div class="testimonial-card">
          <p class="testimonial-quote">
            “The moment I walked in,
            it felt like the space understood me.
            Quiet, minimal, and deeply calming.”
          </p>
          <div class="testimonial-user">
            <img src="https://i.pravatar.cc/100?img=32">
            <div>
              <h4>Riya Sharma</h4>
              <span>Delhi</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-quote">
            “Not just a stay —
            it felt like a reset.
            Everything from light to textures
            was thoughtfully done.”
          </p>
          <div class="testimonial-user">
            <img src="https://i.pravatar.cc/100?img=12">
            <div>
              <h4>Aman Verma</h4>
              <span>Bangalore</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-quote">
            “I've stayed in many places,
            but this one had a soul.
            You can feel the intention behind it.”
          </p>
          <div class="testimonial-user">
            <img src="https://i.pravatar.cc/100?img=45">
            <div>
              <h4>Neha Kapoor</h4>
              <span>Mumbai</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-quote">
            “The silence here
            felt expensive in the best way.”
          </p>
          <div class="testimonial-user">
            <img src="https://i.pravatar.cc/100?img=22">
            <div>
              <h4>Arjun Mehta</h4>
              <span>Pune</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-quote">
            “We booked for two nights
            and ended up extending our stay.
            That says everything.”
          </p>
          <div class="testimonial-user">
            <img src="https://i.pravatar.cc/100?img=55">
            <div>
              <h4>Sana Khan</h4>
              <span>Hyderabad</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <%- include('../partials/footer') %>
  </body>

  <script>
    document.querySelector('.scroll-indicator').addEventListener('click', () => {
      document.querySelector('#next-section').scrollIntoView({
        behavior: 'smooth'
      });
    });
    window.addEventListener('scroll', () => {
      const scrollEl = document.querySelector('.scroll-indicator');
      const scrollY = window.scrollY;

      if (scrollY > 100) {
        scrollEl.style.opacity = '0';
        scrollEl.style.pointerEvents = 'none';
      } else {
        scrollEl.style.opacity = '1';
        scrollEl.style.pointerEvents = 'auto';
      }
    });
    const scrollEl = document.querySelector('.scroll-indicator');
    window.addEventListener('scroll', () => {
      let y = window.scrollY;
      scrollEl.style.opacity = 1 - Math.min(y / 150, 1);
    });
    const cta   = document.getElementById('heroCta');
    const icon  = cta.querySelector('.cta-icon');
    const label = cta.querySelector('.cta-label');
    cta.addEventListener('mouseenter', () => {
      const pillW    = cta.offsetWidth;
      const iconW    = icon.offsetWidth;
      const labelW   = label.offsetWidth;
      const leftPad  = 24;
      const rightPad = 6;
      const iconTravel = -(pillW - rightPad - iconW - leftPad+8);
      const labelTravel =leftPad+11;
      icon.style.transform  = `translateX(${iconTravel}px)`;
      icon.style.background = '#c4a96b';
      icon.style.color      = '#1a1a14';
      label.style.transform = `translateX(${labelTravel}px)`;
      cta.style.transform   = 'scale(1.4)';
    });
    cta.addEventListener('mousemove', (e) => {
      const rect = cta.getBoundingClientRect();
      const x = (e.clientX - rect.left - rect.width / 2) / rect.width;
      const y = (e.clientY - rect.top  - rect.height / 2) / rect.height;
      cta.style.transform = `translate(${x * 6}px, ${y * 4}px) scale(1.4)`;
    });
    cta.addEventListener('mouseleave', () => {
      icon.style.transform  = 'translateX(0)';
      icon.style.background = '#1a1a14';
      icon.style.color      = '#F0EDE6';
      label.style.transform = 'translateX(0)';
      label.style.opacity   = '1';
      cta.style.transform   = 'translate(0,0) scale(1)';
    });
    // Live badge — fluctuates naturally between 18–34
    (function () {
      const el = document.getElementById('liveCount');
      if (!el) return;
      let count = 23;
      setInterval(() => {
        const delta = Math.floor(Math.random() * 3) - 1; // -1, 0, or +1
        count = Math.min(34, Math.max(18, count + delta));
        el.textContent = count;
      }, 4000);
    })();
    const animations = [
      {
        line: document.getElementById("line1"),
        pins: ["pin1", "pin2"]
      },
      {
        line: document.getElementById("line2"),
        pins: ["pin2", "pin4"]
      },
      {
        line: document.getElementById("line3"),
        pins: ["pin3", "pin1"]
      },
      {
        line: document.getElementById("line4"),
        pins: ["pin4", "pin3"]
      }
    ];
    function runRandomAnimation(){
      document.querySelectorAll('.travel-line')
        .forEach(line => line.classList.remove('active'));
      document.querySelectorAll('.map-pin')
        .forEach(pin => pin.classList.remove('active'));
      const random =
        animations[Math.floor(Math.random() * animations.length)];
      random.line.classList.add('active');
      random.pins.forEach(id => {
        document.getElementById(id).classList.add('active');
      });
      setTimeout(() => {
        random.line.classList.remove('active');
        random.pins.forEach(id => {
          document.getElementById(id).classList.remove('active');
        });
      }, 3500);
    }
    runRandomAnimation();
    setInterval(runRandomAnimation, 4500);

    const video = document.getElementById("experienceVideo");
    const cinematicFrame =
    document.getElementById("cinematicFrame");
    const soundBtn =
    document.getElementById("soundBtn");
    const fullscreenBtn =
    document.getElementById("fullscreenBtn");
    cinematicFrame.addEventListener("mouseenter", () => {
      video.muted = false;
    });
    cinematicFrame.addEventListener("mouseleave", () => {
      video.muted = true;

    });
    soundBtn.addEventListener("click", () => {
      video.muted = !video.muted;
      soundBtn.innerText =
        video.muted
        ? "Enable Sound"
        : "Sound On";
    });
    fullscreenBtn.addEventListener("click", async () => {
      if(video.requestFullscreen){
        await video.requestFullscreen();
      }
      video.muted = false;
      soundBtn.innerText = "Sound On";
    });
    const testimonialTrack =
    document.querySelector(".testimonial-track");
    let reversed = false;
    setInterval(() => {
      reversed = !reversed;
      if(reversed){
        testimonialTrack.classList.add("reverse");
      } else {
        testimonialTrack.classList.remove("reverse");
      }
    }, 32000);
  </script>
</html>



