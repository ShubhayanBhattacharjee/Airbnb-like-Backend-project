<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <!-- hero section -->
  <div class="hero-frame">
    <section class="hero">
      <div class="hero-bg">
        <img src="/images/hero2.png" alt="Luxury Farmhouse">
      </div>
      <div class="hero-body">
        <span class="hero-eyebrow">Slow Travel · Real Connection</span>
        <h1 class="hero-title">
          <span class="line-1">Where calm</span>
          <span class="line-2">meets <em>luxury.</em></span>
        </h1>
        <p class="hero-sub">Not a place to escape life, but to return to it.</p>
        <a href="/explore" class="hero-cta" id="heroCta">
          <span class="cta-label">Discover Stays</span>
          <span class="cta-icon">→</span>
        </a>
      </div>
      <div class="hero-live-badge">
        <span class="live-dot"></span>
        <span><span class="live-count" id="liveCount">23</span> people exploring stays right now</span>
      </div>
      <div class="hero-signals">
        <div class="signal-card">
          <span class="signal-icon">🌿</span>
          <div>
            <strong>Off-grid</strong>
            <span>by choice</span>
          </div>
        </div>
        <div class="signal-card">
          <span class="signal-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M2 8C6 4 18 4 22 8" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 12C8 9 16 9 19 12" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8.5 16C10.5 14.5 13.5 14.5 15.5 16" stroke="currentColor" stroke-width="1.5"/>
              <line x1="3" y1="3" x2="21" y2="21" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </span>
          <div>
            <strong>Disconnect</strong>
            <span>to reconnect</span>
          </div>
        </div>
        <div class="signal-card">
          <span class="signal-icon">🌲</span>
          <div>
            <strong>Curated stays</strong>
            <span>in nature</span>
          </div>
        </div>
      </div>
      <div class="hero-ambience">
        18°C · Pinewood Retreat
      </div>
      <div class="scroll-indicator">
        <div class="scroll-mouse">
          <div class="scroll-dot"></div>
        </div>
        <span class="scroll-text">SCROLL TO DISCOVER</span>
      </div>
      <div class="hero-dock">
        <div class="hero-socials">
          <a href="#">🐦</a>
          <a href="#">🌐</a>
          <a href="#">in</a>
        </div>
      </div>
      <!-- <div class="hero-brand">HomeStays</div> -->
    </section>
  </div>

  <!-- philosophy section -->
  <section class="philosophy-section">
    <div class="philosophy-label">
      OUR PHILOSOPHY
    </div>
    <h2 class="philosophy-text">
      <span class="center-line">
        Travel should not pull 
      </span>
      <strong>you away from life.</strong> The right stay slows everything down —
      giving you space to <strong>reconnect with nature</strong>,
      with people, and with yourself.
    </h2>
    <div class="world-inner">
      <div class="world-label">
        OUR WORLD OF STAYS
      </div>
      <div class="world-content">
        <div class="world-map-area">
          <img
            src="/images/explore_world.png"
            alt="World Map"
            class="world-map">
          <svg class="travel-path" viewBox="0 0 1000 500" preserveAspectRatio="none">
            <!-- canada -> poland -->
            <path
              id="line1"
              class="travel-line"
              d="M190 160 C350 90, 470 120, 590 170"
            />
            <!-- poland -> australia -->
            <path
              id="line2"
              class="travel-line"
              d="M590 170 C760 240, 820 330, 860 420"
            />
            <!-- argentina -> canada -->
            <path
              id="line3"
              class="travel-line"
              d="M310 390 C180 330, 120 250, 190 160"
            />
            <!-- australia -> argentina -->
            <path
              id="line4"
              class="travel-line"
              d="M860 420 C720 470, 500 470, 310 390"
            />
          </svg>
          <div class="map-pin pin-1" id="pin1">
            <div class="pin-dot"></div>
            <div class="pin-card">
              <img src="/images/stay1.png">
              <div>
                <strong>Forest Cabin</strong>
                <span>Canada</span>
                <small>48.4284° N, 1.3656° W</small>
              </div>
            </div>
          </div>
          <div class="map-pin pin-2" id="pin2">
            <div class="pin-dot"></div>
            <div class="pin-card">
              <img src="/images/stay2.png">
              <div>
                <strong>Snow Home</strong>
                <span>Poland</span>
                <small>4.4284° N, 1.3656° W</small>
              </div>
            </div>
          </div>
          <div class="map-pin pin-3" id="pin3">
            <div class="pin-dot"></div>
            <div class="pin-card">
              <img src="/images/stay3.png">
              <div>
                <strong>Cliff House</strong>
                <span>Argentina</span>
                <small>37.7179° N, 8.5981° W</small>
              </div>
            </div>
          </div>
          <div class="map-pin pin-4" id="pin4">
            <div class="pin-dot"></div>
            <div class="pin-card">
              <img src="/images/stay4.png">
              <div>
                <strong>Beach Calm</strong>
                <span>Australia</span>
                <small>8.4095° S, 115.1889° E</small>
              </div>
            </div>
          </div>
        </div>
        <div class="world-copy">
          <h2>
            Discover stays
            shaped by
            <em>nature, silence,</em>
            and <em>slower living</em>.
          </h2>
          <p>
            Handpicked homes across forests,
            coastlines, mountains, and hidden
            landscapes around the world. All available with HomeStays and We're with you.
          </p>
          <a href="/explore" class="explore-btn">
            <span>EXPLORE STAYS</span>
            <div class="btn-arrow">
              →
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>


  <main id="listings">
    <div class="listings-header">
      <h2>curated stays</h2>
      <a href="/host/addHome" class="view-all-link">+ add your home →</a>
    </div>

    <ul class="home-list">
      <% registeredHomes.forEach(home => { %>
      <li class="home-card">
        <div class="card-image-wrap">
          <img src="<%= home.photo %>" alt="<%= home.houseName %>">
          <button class="heart-btn" aria-label="Save">♡</button>
        </div>
        <div class="home-content">
          <div class="card-top">
            <h3 class="home-name"><%= home.houseName %></h3>
            <p class="home-location"><%= home.location %></p>
          </div>
          <div class="card-bottom">
            <p class="home-price">₹<%= home.price %> <span>/ night</span></p>
            <p class="home-bedrooms"><%= home.no_of_bedRooms %> bed</p>
          </div>
          <button class="booking">book now</button>
        </div>
      </li>
      <% }); %>
    </ul>
  </main>

  <section class="testimonials">
    <div class="testimonials-inner">
      <div class="testimonials-header">
        <h2>What people <em>feel</em> after staying</h2>
        <p>Real experiences from guests who found more than just a place to stay.</p>
      </div>
      <div class="testimonial-grid">
        <div class="testimonial-card">
          <p class="testimonial-text">"The moment I walked in, it felt like the space understood me. Quiet, minimal, and deeply calming."</p>
          <div class="testimonial-user">
            <img src="https://i.pravatar.cc/100?img=32" alt="">
            <div><h4>Riya Sharma</h4><span>Delhi</span></div>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-text">"Not just a stay — it felt like a reset. Everything from light to textures was thoughtfully done."</p>
          <div class="testimonial-user">
            <img src="https://i.pravatar.cc/100?img=12" alt="">
            <div><h4>Aman Verma</h4><span>Bangalore</span></div>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-text">"I've stayed in many places, but this one had a soul. You can feel the intention behind it."</p>
          <div class="testimonial-user">
            <img src="https://i.pravatar.cc/100?img=45" alt="">
            <div><h4>Neha Kapoor</h4><span>Mumbai</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%- include('../partials/footer') %>
  </body>

  <script>
    document.querySelector('.scroll-indicator').addEventListener('click', () => {
      document.querySelector('#next-section').scrollIntoView({
        behavior: 'smooth'
      });
    });
    window.addEventListener('scroll', () => {
      const scrollEl = document.querySelector('.scroll-indicator');
      const scrollY = window.scrollY;

      if (scrollY > 100) {
        scrollEl.style.opacity = '0';
        scrollEl.style.pointerEvents = 'none';
      } else {
        scrollEl.style.opacity = '1';
        scrollEl.style.pointerEvents = 'auto';
      }
    });
    const scrollEl = document.querySelector('.scroll-indicator');
    window.addEventListener('scroll', () => {
      let y = window.scrollY;
      scrollEl.style.opacity = 1 - Math.min(y / 150, 1);
    });
    const cta   = document.getElementById('heroCta');
    const icon  = cta.querySelector('.cta-icon');
    const label = cta.querySelector('.cta-label');
    cta.addEventListener('mouseenter', () => {
      const pillW    = cta.offsetWidth;
      const iconW    = icon.offsetWidth;
      const labelW   = label.offsetWidth;
      const leftPad  = 24;
      const rightPad = 6;
      const iconTravel = -(pillW - rightPad - iconW - leftPad+8);
      const labelTravel =leftPad+11;
      icon.style.transform  = `translateX(${iconTravel}px)`;
      icon.style.background = '#c4a96b';
      icon.style.color      = '#1a1a14';
      label.style.transform = `translateX(${labelTravel}px)`;
      cta.style.transform   = 'scale(1.4)';
    });
    cta.addEventListener('mousemove', (e) => {
      const rect = cta.getBoundingClientRect();
      const x = (e.clientX - rect.left - rect.width / 2) / rect.width;
      const y = (e.clientY - rect.top  - rect.height / 2) / rect.height;
      cta.style.transform = `translate(${x * 6}px, ${y * 4}px) scale(1.4)`;
    });
    cta.addEventListener('mouseleave', () => {
      icon.style.transform  = 'translateX(0)';
      icon.style.background = '#1a1a14';
      icon.style.color      = '#F0EDE6';
      label.style.transform = 'translateX(0)';
      label.style.opacity   = '1';
      cta.style.transform   = 'translate(0,0) scale(1)';
    });
    // Live badge — fluctuates naturally between 18–34
    (function () {
      const el = document.getElementById('liveCount');
      if (!el) return;
      let count = 23;
      setInterval(() => {
        const delta = Math.floor(Math.random() * 3) - 1; // -1, 0, or +1
        count = Math.min(34, Math.max(18, count + delta));
        el.textContent = count;
      }, 4000);
    })();
    const animations = [
      {
        line: document.getElementById("line1"),
        pins: ["pin1", "pin2"]
      },
      {
        line: document.getElementById("line2"),
        pins: ["pin2", "pin4"]
      },
      {
        line: document.getElementById("line3"),
        pins: ["pin3", "pin1"]
      },
      {
        line: document.getElementById("line4"),
        pins: ["pin4", "pin3"]
      }
    ];
    function runRandomAnimation(){
      document.querySelectorAll('.travel-line')
        .forEach(line => line.classList.remove('active'));
      document.querySelectorAll('.map-pin')
        .forEach(pin => pin.classList.remove('active'));
      const random =
        animations[Math.floor(Math.random() * animations.length)];
      random.line.classList.add('active');
      random.pins.forEach(id => {
        document.getElementById(id).classList.add('active');
      });
      setTimeout(() => {
        random.line.classList.remove('active');
        random.pins.forEach(id => {
          document.getElementById(id).classList.remove('active');
        });
      }, 3500);
    }
    runRandomAnimation();
    setInterval(runRandomAnimation, 4500);
  </script>
</html>



