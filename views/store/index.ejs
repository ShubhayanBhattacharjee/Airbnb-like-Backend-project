<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/navbar') %>

<!-- HERO — full bleed image with text + search bar -->
<section class="hero">
  <img src="/images/hero.jpg" alt="Beautiful stay" class="hero-bg" />
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <h1>Slow Travel<br>Beautifully <em>hosted</em></h1>
    <p>A small, considered collection of homes — from glass cabins to coastal cottages. <br/>Book directly with the people who care for them.</p>
    <a href="#listings" class="btn-explore">explore stays →</a>
  </div>

  <!-- SEARCH BAR floats at bottom of hero -->
  <div class="search-bar">
    <div class="search-field">
      <span class="search-label">where</span>
      <div class="search-input-row">
        <input type="text" placeholder="any destination" />
        <span class="search-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
      </div>
    </div>
    <div class="search-divider"></div>
    <div class="search-field">
      <span class="search-label">check in – check out</span>
      <div class="search-input-row">
        <input type="text" placeholder="add dates" />
        <span class="search-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </span>
      </div>
    </div>
    <div class="search-divider"></div>
    <div class="search-field">
      <span class="search-label">guests</span>
      <div class="search-input-row">
        <input type="text" placeholder="2 guests" />
        <span class="search-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </span>
      </div>
    </div>
    <button class="search-btn" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </button>
  </div>
</section>

<!-- MOOD FILTERS -->
<section class="mood-section">
  <div class="mood-header">
    <p class="mood-tagline">Find stays that match<br><strong>your <em>mood.</em></strong></p>
    <div class="mood-chips">
      <button class="mood-chip active">☀️ peaceful</button>
      <button class="mood-chip">🌊 near water</button>
      <button class="mood-chip">🏡 minimal</button>
      <button class="mood-chip">🌲 nature escape</button>
      <button class="mood-chip">More Coming Soon</button>
    </div>
  </div>
</section>

<!-- LISTINGS -->
<main id="listings">
  <div class="listings-header">
    <h2>curated stays</h2>
    <a href="/host/addHome" class="view-all-link">+ add your home →</a>
  </div>

  <ul class="home-list">
    <% registeredHomes.forEach(home => { %>
    <li class="home-card">
      <div class="card-image-wrap">
        <img src="<%= home.photo %>" alt="<%= home.houseName %>">
        <button class="heart-btn" aria-label="Save">♡</button>
      </div>
      <div class="home-content">
        <div class="card-top">
          <h3 class="home-name"><%= home.houseName %></h3>
          <p class="home-location"><%= home.location %></p>
        </div>
        <div class="card-bottom">
          <p class="home-price">₹<%= home.price %> <span>/ night</span></p>
          <p class="home-bedrooms"><%= home.no_of_bedRooms %> bed</p>
        </div>
        <button class="booking">book now</button>
      </div>
    </li>
    <% }); %>
  </ul>
</main>

<section class="testimonials">
  <div class="testimonials-inner">

    <!-- HEADER -->
    <div class="testimonials-header">
      <h2>What people <em>feel</em> after staying</h2>
      <p>Real experiences from guests who found more than just a place to stay.</p>
    </div>

    <!-- CARDS -->
    <div class="testimonial-grid">

      <div class="testimonial-card">
        <p class="testimonial-text">
          “The moment I walked in, it felt like the space understood me. Quiet, minimal, and deeply calming.”
        </p>
        <div class="testimonial-user">
          <img src="https://i.pravatar.cc/100?img=32" alt="">
          <div>
            <h4>Riya Sharma</h4>
            <span>Delhi</span>
          </div>
        </div>
      </div>

      <div class="testimonial-card">
        <p class="testimonial-text">
          “Not just a stay — it felt like a reset. Everything from light to textures was thoughtfully done.”
        </p>
        <div class="testimonial-user">
          <img src="https://i.pravatar.cc/100?img=12" alt="">
          <div>
            <h4>Aman Verma</h4>
            <span>Bangalore</span>
          </div>
        </div>
      </div>

      <div class="testimonial-card">
        <p class="testimonial-text">
          “I’ve stayed in many places, but this one had a soul. You can feel the intention behind it.”
        </p>
        <div class="testimonial-user">
          <img src="https://i.pravatar.cc/100?img=45" alt="">
          <div>
            <h4>Neha Kapoor</h4>
            <span>Mumbai</span>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>

<%- include('../partials/footer') %>
</body>
</html>