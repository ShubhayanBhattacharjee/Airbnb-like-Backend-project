<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/navbar') %>

<!-- hero section -->
<div class="hero-frame">
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/hero2.png" alt="Luxury Farmhouse">
    </div>
    <div class="hero-body">
      <span class="hero-eyebrow">Slow Travel · Real Connection</span>
      <h1 class="hero-title">
        <span class="line-1">Where luxury</span>
        <span class="line-2">finds solitude.</span>
      </h1>
      <p class="hero-sub">For those who travel not to escape life,<br> but to find it.</p>
    </div>
    <div class="hero-dock">
      <div class="hero-socials">
        <a href="#">🐦</a>
        <a href="#">🌐</a>
        <a href="#">in</a>
      </div>
    </div>
    <!-- <div class="hero-brand">HomeStays</div> -->
  </section>
</div>


<div class="feature-strip">
  <div class="feature-item">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <div>
      <strong>Curated Homes</strong>
      <span>Handpicked for design,<br>comfort and location.</span>
    </div>
  </div>
  <div class="feature-divider"></div>
  <div class="feature-item">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 1 0 20A10 10 0 0 1 12 2z"/><path d="M12 8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/><path d="M12 14c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
    <div>
      <strong>Nature First</strong>
      <span>Stays that bring you<br>closer to nature.</span>
    </div>
  </div>
  <div class="feature-divider"></div>
  <div class="feature-item">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    <div>
      <strong>Thoughtful Hosts</strong>
      <span>Hosted by people who<br>truly care.</span>
    </div>
  </div>
  <div class="feature-divider"></div>
  <div class="feature-item">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    <div>
      <strong>Secure Booking</strong>
      <span>Book directly with<br>confidence.</span>
    </div>
  </div>
</div>

<section class="mood-section">
  <div class="mood-header">
    <p class="mood-tagline">Find stays that match<br><strong>your <em>mood.</em></strong></p>
    <div class="mood-chips">
      <button class="mood-chip active">☀️ peaceful</button>
      <button class="mood-chip">🌊 near water</button>
      <button class="mood-chip">🏡 minimal</button>
      <button class="mood-chip">🌲 nature escape</button>
      <button class="mood-chip">More Coming Soon</button>
    </div>
  </div>
</section>

<main id="listings">
  <div class="listings-header">
    <h2>curated stays</h2>
    <a href="/host/addHome" class="view-all-link">+ add your home →</a>
  </div>

  <ul class="home-list">
    <% registeredHomes.forEach(home => { %>
    <li class="home-card">
      <div class="card-image-wrap">
        <img src="<%= home.photo %>" alt="<%= home.houseName %>">
        <button class="heart-btn" aria-label="Save">♡</button>
      </div>
      <div class="home-content">
        <div class="card-top">
          <h3 class="home-name"><%= home.houseName %></h3>
          <p class="home-location"><%= home.location %></p>
        </div>
        <div class="card-bottom">
          <p class="home-price">₹<%= home.price %> <span>/ night</span></p>
          <p class="home-bedrooms"><%= home.no_of_bedRooms %> bed</p>
        </div>
        <button class="booking">book now</button>
      </div>
    </li>
    <% }); %>
  </ul>
</main>


<section class="testimonials">
  <div class="testimonials-inner">
    <div class="testimonials-header">
      <h2>What people <em>feel</em> after staying</h2>
      <p>Real experiences from guests who found more than just a place to stay.</p>
    </div>
    <div class="testimonial-grid">
      <div class="testimonial-card">
        <p class="testimonial-text">"The moment I walked in, it felt like the space understood me. Quiet, minimal, and deeply calming."</p>
        <div class="testimonial-user">
          <img src="https://i.pravatar.cc/100?img=32" alt="">
          <div><h4>Riya Sharma</h4><span>Delhi</span></div>
        </div>
      </div>
      <div class="testimonial-card">
        <p class="testimonial-text">"Not just a stay — it felt like a reset. Everything from light to textures was thoughtfully done."</p>
        <div class="testimonial-user">
          <img src="https://i.pravatar.cc/100?img=12" alt="">
          <div><h4>Aman Verma</h4><span>Bangalore</span></div>
        </div>
      </div>
      <div class="testimonial-card">
        <p class="testimonial-text">"I've stayed in many places, but this one had a soul. You can feel the intention behind it."</p>
        <div class="testimonial-user">
          <img src="https://i.pravatar.cc/100?img=45" alt="">
          <div><h4>Neha Kapoor</h4><span>Mumbai</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
</body>

<script>
(function () {
  /* ── custom cursor ── */
  


  /* ── letterbox open ── */
  setTimeout(() => {
    document.getElementById('heroBarTop').style.height = '0px';
    document.getElementById('heroBarBot').style.height = '0px';
  }, 350);

  /* ── slideshow ── */
  const slides = [...document.querySelectorAll('.hero-slide')];
  const total  = slides.length;
  let cur = 0, timer = null;

  /* build dots */
  const prog = document.getElementById('heroProgress');
  slides.forEach((_, i) => {
    const d = document.createElement('div');
    d.className = 'hero-pdot' + (i === 0 ? ' active' : '');
    d.addEventListener('click', () => goTo(i));
    prog.appendChild(d);
  });

  function updateMeta(idx) {
    document.getElementById('heroSceneNum').textContent  = slides[idx].dataset.num + ' / 0' + total;
    document.getElementById('heroSceneName').textContent = slides[idx].dataset.label;
  }

  function goTo(n) {
    /* fade out current */
    slides[cur].classList.remove('active');
    const oldImg = slides[cur].querySelector('img');
    oldImg.style.animation = 'none';
    void oldImg.offsetWidth; // reflow reset

    document.querySelectorAll('.hero-pdot')[cur].classList.remove('active');
    cur = n;

    slides[cur].classList.add('active');
    const newImg = slides[cur].querySelector('img');
    newImg.style.animation = '';

    document.querySelectorAll('.hero-pdot')[cur].classList.add('active');
    updateMeta(cur);
    clearTimeout(timer);
    schedNext();
  }

  function schedNext() { timer = setTimeout(() => goTo((cur + 1) % total), 7000); }
  schedNext();

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight') goTo((cur + 1) % total);
    if (e.key === 'ArrowLeft')  goTo((cur - 1 + total) % total);
  });
})();
</script>
</html>



