<%- include('../partials/header', { pageTitle: "My Profile" }) %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css">
</head>

<body>
<%- include('../partials/navbar') %>

<main style="max-width:900px;margin:60px auto;padding:24px;">

  <!-- SUCCESS / ERROR MESSAGES -->
  <% if (success) { %>
    <div style="background:#dcfce7;color:#166534;padding:12px 16px;border-radius:10px;margin-bottom:20px;font-size:14px;">
      <i class="ri-checkbox-circle-line"></i> <%= success %>
    </div>
  <% } %>
  <% if (errors && errors.length > 0) { %>
    <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:10px;margin-bottom:20px;font-size:14px;">
      <% errors.forEach(e => { %><p style="margin:0"><i class="ri-error-warning-line"></i> <%= e %></p><% }) %>
    </div>
  <% } %>

  <div style="display:grid;grid-template-columns:1fr 2fr;gap:24px;align-items:start;">

    <!-- LEFT: AVATAR + STATS -->
    <div>

      <!-- Avatar -->
      <div style="background:#fff;border:0.5px solid #e5e7eb;border-radius:16px;padding:24px;text-align:center;margin-bottom:16px;">
        <img
          src="<%= user.profileImage %>"
          alt="<%= user.fname %>"
          style="width:100px;height:100px;border-radius:50%;object-fit:cover;margin-bottom:12px;border:3px solid #f3f4f6;"
        >
        <h2 style="margin:0 0 4px;font-size:18px;"><%= user.fname %> <%= user.lname %></h2>
        <p style="margin:0 0 8px;color:#6b7280;font-size:13px;">
          <i class="ri-map-pin-line"></i>
          <%= user.location %><% if(user.country && user.country !== 'Unknown') { %>, <%= user.country %><% } %>
        </p>
        <span style="background:#f3f4f6;color:#374151;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:500;">
          <%= user.role === 'host' ? '🏠 Host' : '✈️ Guest' %>
        </span>
        <p style="margin:12px 0 0;font-size:12px;color:#9ca3af;">
          Member since <%= new Date(user._id.getTimestamp()).toLocaleDateString('en-IN', { month: 'long', year: 'numeric' }) %>
        </p>
      </div>

      <!-- Stats -->
      <div style="background:#fff;border:0.5px solid #e5e7eb;border-radius:16px;padding:20px;">
        <h3 style="margin:0 0 16px;font-size:15px;color:#374151;">Stats</h3>

        <% if (user.role === 'guest') { %>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div style="background:#f9fafb;border-radius:10px;padding:14px;text-align:center;">
              <p style="font-size:22px;font-weight:700;margin:0;color:#1a1a2e;"><%= stats.totalBookings || 0 %></p>
              <p style="font-size:11px;color:#6b7280;margin:4px 0 0;">Total Bookings</p>
            </div>
            <div style="background:#f9fafb;border-radius:10px;padding:14px;text-align:center;">
              <p style="font-size:22px;font-weight:700;margin:0;color:#1a1a2e;"><%= stats.completedBookings || 0 %></p>
              <p style="font-size:11px;color:#6b7280;margin:4px 0 0;">Stays Completed</p>
            </div>
            <div style="background:#f9fafb;border-radius:10px;padding:14px;text-align:center;grid-column:span 2;">
              <p style="font-size:22px;font-weight:700;margin:0;color:#1a1a2e;"><%= stats.upcomingBookings || 0 %></p>
              <p style="font-size:11px;color:#6b7280;margin:4px 0 0;">Upcoming Stays</p>
            </div>
          </div>

        <% } else { %>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div style="background:#f9fafb;border-radius:10px;padding:14px;text-align:center;">
              <p style="font-size:22px;font-weight:700;margin:0;color:#1a1a2e;"><%= stats.totalListings || 0 %></p>
              <p style="font-size:11px;color:#6b7280;margin:4px 0 0;">Listings</p>
            </div>
            <div style="background:#f9fafb;border-radius:10px;padding:14px;text-align:center;">
              <p style="font-size:22px;font-weight:700;margin:0;color:#1a1a2e;"><%= stats.totalGuests || 0 %></p>
              <p style="font-size:11px;color:#6b7280;margin:4px 0 0;">Guests Hosted</p>
            </div>
            <div style="background:#f9fafb;border-radius:10px;padding:14px;text-align:center;grid-column:span 2;">
              <p style="font-size:22px;font-weight:700;margin:0;color:#166534;">₹<%= (stats.totalEarnings || 0).toLocaleString('en-IN') %></p>
              <p style="font-size:11px;color:#6b7280;margin:4px 0 0;">Total Earnings</p>
            </div>
          </div>
        <% } %>
      </div>

    </div>

    <!-- RIGHT: EDIT FORM -->
    <div style="background:#fff;border:0.5px solid #e5e7eb;border-radius:16px;padding:28px;">
      <h2 style="margin:0 0 20px;font-size:18px;">Edit Profile</h2>

      <form action="/profile" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">

          <div>
            <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:4px;">First name</label>
            <input type="text" name="fname" value="<%= user.fname %>"
              style="width:100%;padding:9px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;box-sizing:border-box;">
          </div>

          <div>
            <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:4px;">Last name</label>
            <input type="text" name="lname" value="<%= user.lname %>"
              style="width:100%;padding:9px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;box-sizing:border-box;">
          </div>

          <div style="grid-column:span 2;">
            <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:4px;">Middle name <span style="color:#9ca3af;">(optional)</span></label>
            <input type="text" name="mname" value="<%= user.mname || '' %>"
              style="width:100%;padding:9px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;box-sizing:border-box;">
          </div>

          <div>
            <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:4px;">Location</label>
            <input type="text" name="location" value="<%= user.location !== 'Unknown' ? user.location : '' %>"
              style="width:100%;padding:9px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;box-sizing:border-box;">
          </div>

          <div>
            <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:4px;">Country</label>
            <input type="text" name="country" value="<%= user.country !== 'Unknown' ? user.country : '' %>"
              style="width:100%;padding:9px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;box-sizing:border-box;">
          </div>

          <div style="grid-column:span 2;">
            <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:4px;">Phone</label>
            <input type="text" name="phone" value="<%= user.phone || '' %>"
              style="width:100%;padding:9px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;box-sizing:border-box;">
          </div>

          <div style="grid-column:span 2;">
            <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:4px;">Bio</label>
            <textarea name="bio" rows="4"
              style="width:100%;padding:9px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;resize:vertical;box-sizing:border-box;"><%= user.bio || '' %></textarea>
          </div>

          <div style="grid-column:span 2;">
            <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:4px;">Profile photo</label>
            <input type="file" name="photo" accept="image/jpeg,image/png"
              style="font-size:13px;color:#6b7280;">
            <p style="font-size:12px;color:#9ca3af;margin:4px 0 0;">JPG or PNG, max 2MB. Leave empty to keep current photo.</p>
          </div>

        </div>

        <button type="submit"
          style="margin-top:20px;width:100%;padding:12px;background:#1a1a2e;color:#fff;border:none;border-radius:10px;font-size:15px;cursor:pointer;">
          Save Changes
        </button>

      </form>
    </div>

  </div>

</main>

</body>
</html>