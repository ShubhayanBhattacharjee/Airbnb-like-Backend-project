<%- include('../partials/header', { pageTitle: "Booking Confirmed" }) %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css">
</head>
<body>
<%- include('../partials/navbar') %>

<main style="max-width:600px;margin:80px auto;padding:24px;text-align:center;">
  <div style="font-size:64px;margin-bottom:16px;">🎉</div>
  <h1 style="font-size:28px;margin-bottom:8px;">Booking Confirmed!</h1>
  <p style="color:#6b7280;margin-bottom:32px;">Your stay has been reserved. See you there!</p>

  <div style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:16px;padding:24px;text-align:left;">
    <img src="<%= booking.home.photo %>" alt="" style="width:100%;height:200px;object-fit:cover;border-radius:10px;margin-bottom:20px;">
    <h2 style="margin:0 0 4px;"><%= booking.home.houseName %></h2>
    <p style="color:#6b7280;margin:0 0 20px;"><i class="ri-map-pin-line"></i> <%= booking.home.location %></p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">
      <div>
        <p style="font-size:12px;color:#9ca3af;margin:0;">Check-in</p>
        <p style="font-weight:600;margin:0;"><%= new Date(booking.checkIn).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></p>
      </div>
      <div>
        <p style="font-size:12px;color:#9ca3af;margin:0;">Check-out</p>
        <p style="font-weight:600;margin:0;"><%= new Date(booking.checkOut).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></p>
      </div>
      <div>
        <p style="font-size:12px;color:#9ca3af;margin:0;">Guests</p>
        <p style="font-weight:600;margin:0;"><%= booking.guests %> guest<%= booking.guests > 1 ? 's' : '' %></p>
      </div>
      <div>
        <p style="font-size:12px;color:#9ca3af;margin:0;">Duration</p>
        <p style="font-weight:600;margin:0;"><%= booking.nights %> night<%= booking.nights > 1 ? 's' : '' %></p>
      </div>
    </div>

    <div style="border-top:1px solid #e5e7eb;padding-top:16px;display:flex;justify-content:space-between;align-items:center;">
      <span style="font-size:14px;color:#6b7280;">Total Paid</span>
      <span style="font-size:22px;font-weight:700;">₹<%= booking.totalPrice %></span>
    </div>
    <p style="font-size:12px;color:#9ca3af;margin:8px 0 0;">Payment ID: <%= booking.razorpayPaymentId %></p>
  </div>

  <div style="margin-top:24px;display:flex;gap:12px;justify-content:center;">
    <a href="/bookings" style="padding:12px 24px;background:#1a1a2e;color:#fff;border-radius:8px;text-decoration:none;">
      View My Bookings
    </a>
    <a href="/homeList" style="padding:12px 24px;border:1px solid #e5e7eb;border-radius:8px;text-decoration:none;color:#374151;">
      Explore More
    </a>
  </div>
</main>
</body>
</html>