<%- include('../partials/header', { pageTitle: home.houseName }) %>

<link rel="stylesheet" href="/css/homeDetails.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css">
<style>
  .star-filled { color: #f59e0b; }
  .star-empty  { color: #d1d5db; }
</style>
</head>

<body class="details-body">

<%- include('../partials/navbar') %>

<main class="details-page">

  <!-- HERO -->

  <section class="details-hero">

    <!-- LEFT -->

    <div class="details-info">

      <a href="/homeList" class="back-link" id="backToHomes">
        <i class="ri-arrow-left-s-line"></i>
        Back to homes
      </a>

      <h1><%= home.houseName %></h1>

      <p class="details-location">
        <i class="ri-map-pin-line"></i>
        <%= home.location %>
      </p>

      <p class="details-description">
        <%= home.description %>
      </p>

      <div class="details-meta">

        <div class="meta-item">
          <i class="ri-star-fill"></i>
          <span><%= home.reviewCount > 0 ? home.avgRating : 'New' %></span>
        </div>

        <div class="meta-item">
          <i class="ri-shield-check-line"></i>
          <span>Superhost</span>
        </div>

      </div>

      <!-- FEATURES -->

      <div class="feature-grid">

        <div class="feature-card">
          <i class="ri-user-line"></i>
          <span>4 Guests</span>
        </div>

        <div class="feature-card">
          <i class="ri-hotel-bed-line"></i>
          <span><%= home.no_of_bedRooms %> Bedrooms</span>
        </div>

        <div class="feature-card">
          <i class="ri-home-4-line"></i>
          <span>Entire Home</span>
        </div>

        <div class="feature-card">
          <i class="ri-wifi-line"></i>
          <span>Wi-Fi</span>
        </div>

      </div>

      <!-- BUTTONS -->

      <div class="details-actions">

        <button class="availability-btn">
          Check Availability
        </button>

        <form action="/favourites" method="POST">
          <input
              type="hidden"
              name="_csrf"
              value="<%= csrfToken %>"
          >
          <input
              type="hidden"
              name="homeId"
              value="<%= home._id %>"
          >
          <button type="submit" class="wishlist-btn">
            <% if(isFavourite){ %>
                <i class="ri-heart-fill"></i>
            <% } else { %>
                <i class="ri-heart-3-line"></i>
            <% } %>
          </button>
        </form>
      </div>
    </div>

    <!-- RIGHT -->

    <div class="details-gallery">

      <div class="main-image">
        <img src="<%= home.photo %>" alt="<%= home.houseName %>">
      </div>

      <div class="gallery-grid">

        <img src="<%= home.photo %>" alt="">
        <img src="<%= home.photo %>" alt="">
        <img src="<%= home.photo %>" alt="">
        <img src="<%= home.photo %>" alt="">

      </div>

    </div>

  </section>

  <!-- TABS -->

  <section class="details-tabs">

    <a href="#">Overview</a>
    <a href="#amenities">Amenities</a>
    <a href="#location">Location</a>
    <a href="#reviews">Reviews</a>
    <a href="#host">Host</a>
    <a href="#">House Rules</a>

  </section>

  <!-- CONTENT -->

  <section class="details-content">

    <!-- LEFT -->

    <div class="content-left">

      <div class="about-section">

        <h2>About this home</h2>

        <p>
          <%= home.description %>
        </p>

      </div>

      <!-- AMENITIES -->

      <div class="amenities-grid" id="amenities">

        <div class="amenity-card">
          <i class="ri-plant-line"></i>
          <div>
            <h4>Private Infinity Pool</h4>
            <p>Overlooking nature.</p>
          </div>
        </div>

        <div class="amenity-card">
          <i class="ri-landscape-line"></i>
          <div>
            <h4>Panoramic Views</h4>
            <p>Mountains & sea views.</p>
          </div>
        </div>

        <div class="amenity-card">
          <i class="ri-goblet-line"></i>
          <div>
            <h4>Outdoor Dining</h4>
            <p>Luxury open dining.</p>
          </div>
        </div>

        <div class="amenity-card">
          <i class="ri-home-heart-line"></i>
          <div>
            <h4>Luxury Interiors</h4>
            <p>Premium architecture.</p>
          </div>
        </div>

      </div>

      <!-- MAP CARD -->

      <div class="location-card" id="location">

        <div class="map-placeholder">
          <h3><%= home.location %></h3>
          <p>Beautiful surroundings with breathtaking views.</p>
        </div>

        <div class="location-info">

          <div>
            <i class="ri-map-pin-line"></i>
            <span>Prime Location</span>
          </div>

          <div>
            <i class="ri-road-map-line"></i>
            <span>Nearby Attractions</span>
          </div>

          <div>
            <i class="ri-restaurant-line"></i>
            <span>Restaurants Nearby</span>
          </div>

        </div>

      </div>

      <!-- REVIEWS SECTION -->
      <div class="reviews-section" style="margin-top:40px;" id="reviews">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
          <h2 style="margin:0;">Reviews</h2>
          <% if (home.reviewCount > 0) { %>
            <span style="display:flex;align-items:center;gap:4px;font-size:16px;">
              <i class="ri-star-fill" style="color:#f59e0b;"></i>
              <strong><%= home.avgRating %></strong>
              <span style="color:#6b7280;font-size:14px;">(<%= home.reviewCount %> review<%= home.reviewCount !== 1 ? 's' : '' %>)</span>
            </span>
          <% } else { %>
            <span style="color:#9ca3af;font-size:14px;">No reviews yet</span>
          <% } %>
        </div>

        <% if (reviews.length === 0) { %>
          <p style="color:#6b7280;font-size:14px;">Be the first to review this home after your stay.</p>
        <% } else { %>
          <% reviews.forEach(review => { %>
            <div style="padding:16px 0;border-bottom:1px solid #f3f4f6;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <img
                  src="<%= review.guest.profileImage %>"
                  alt="<%= review.guest.fname %>"
                  style="width:36px;height:36px;border-radius:50%;object-fit:cover;"
                >
                <div>
                  <p style="margin:0;font-weight:600;font-size:14px;"><%= review.guest.fname %> <%= review.guest.lname %></p>
                  <p style="margin:0;font-size:12px;color:#9ca3af;">
                    <%= new Date(review.createdAt).toLocaleDateString('en-IN', {month:'long', year:'numeric'}) %>
                  </p>
                </div>
                <div style="margin-left:auto;display:flex;gap:2px;">
                  <% for(let i = 1; i <= 5; i++) { %>
                    <i class="ri-star-<%= i <= review.rating ? 'fill' : 'line' %> <%= i <= review.rating ? 'star-filled' : 'star-empty' %>" style="font-size:14px;"></i>
                  <% } %>
                </div>
              </div>
              <p style="margin:0;font-size:14px;color:#374151;line-height:1.6;"><%= review.comment %></p>
              <% if (review.hostReply && review.hostReply.comment) { %>
                <div class="host-reply">
                    <strong>Host replied:</strong>
                    <p><%= review.hostReply.comment %></p>
                    <small><%= new Date(review.hostReply.repliedAt).toLocaleDateString() %></small>
                </div>
            <% } %>
            <% if (locals.user && locals.user.role === 'host' && 
                home.owner._id.toString() === locals.user._id.toString() &&
                  !(review.hostReply && review.hostReply.comment)) { %>
                <form action="/reviews/reply/<%= review._id %>?_method=POST" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <textarea name="comment" placeholder="Reply to this review..." required minlength="2" maxlength="1000"></textarea>
                    <button type="submit">Post Reply</button>
                </form>
            <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- HOST SECTION — paste here -->
      <div class="host-section" id="host">
        <div class="host-profile">
          <img src="<%= home.owner.profileImage %>" alt="<%= home.owner.fname %>">
          <div>
            <h3><%= home.owner.fname %> <%= home.owner.lname %></h3>
            <p><%= home.owner.bio || '' %></p>
            <p><%= home.owner.location %></p>
            <p><%= home.owner.stays %> stays completed</p>
          </div>
        </div>

        <% if (hostOtherHomes.length > 0) { %>
          <h4>More from this host</h4>
          <div class="host-other-homes">
            <% hostOtherHomes.forEach(h => { %>
              <a href="/homeList/<%= h._id %>" class="mini-home-card">
                <img src="<%= h.photo %>" alt="<%= h.houseName %>">
                <p><%= h.houseName %></p>
                <p>$<%= h.price %>/night · <%= h.no_of_bedRooms %> beds</p>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>


    </div> <!-- end content-left -->
    <!-- RIGHT -->

    <aside class="booking-card">
      <h2>$<%= home.price %> <span>/ night</span></h2>
      <p class="booking-rating">
        <i class="ri-star-fill"></i><span><%= home.reviewCount > 0 ? home.avgRating : 'New' %></span>
      </p>

      <div class="booking-form">
        <div class="booking-dates">
          <div>
            <label>Check in</label>
            <input type="date" id="checkIn" min="<%= new Date().toISOString().split('T')[0] %>">
          </div>
          <div>
            <label>Check out</label>
            <input type="date" id="checkOut" min="<%= new Date().toISOString().split('T')[0] %>">
          </div>
        </div>

        <div class="booking-guests">
          <label>Guests</label>
          <select id="guestsSelect">
            <option value="1">1 guest</option>
            <option value="2">2 guests</option>
            <option value="3">3 guests</option>
            <option value="4">4 guests</option>
          </select>
        </div>

        <!-- Availability result -->
        <div id="availResult" style="display:none; padding:10px; border-radius:8px; margin-bottom:12px; font-size:14px;"></div>

        <!-- Price breakdown (shown after availability check) -->
        <div id="priceBreakdown" style="display:none; font-size:14px; margin-bottom:12px;">
          <div style="display:flex;justify-content:space-between;"><span id="nightsLabel"></span><span id="nightsTotal"></span></div>
          <div style="display:flex;justify-content:space-between;font-weight:700;margin-top:6px;"><span>Total</span><span id="grandTotal"></span></div>
        </div>

        <button class="booking-btn" id="checkBtn" onclick="checkAvailability()">
          Check Availability
        </button>
        <button class="booking-btn" id="bookBtn" style="display:none; background:#16a34a;" onclick="startPayment()">
          Book Now — Pay ₹<span id="payAmount"></span>
        </button>

        <p class="booking-note">
          <i class="ri-information-line"></i> You won't be charged yet until you confirm
        </p>
      </div>
    </aside>

  </section>

</main>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  const HOME_ID    = "<%= home._id %>";
  const IS_LOGGED  = "<%= locals.isLoggedIn ? 'true' : 'false' %>";
  const USER_NAME  = "<%= locals.user ? (user.fname + ' ' + user.lname) : '' %>";
  const USER_EMAIL = "<%= locals.user ? user.email : '' %>";
  const CSRF_TOKEN = "<%= csrfToken %>";
  let _nights = 0, _total = 0;
  async function checkAvailability() {
    const checkIn  = document.getElementById('checkIn').value;
    const checkOut = document.getElementById('checkOut').value;
    const result   = document.getElementById('availResult');
    const priceBox = document.getElementById('priceBreakdown');
    const bookBtn  = document.getElementById('bookBtn');

    if (!checkIn || !checkOut) {
      showResult('Please select both dates.', '#fef3c7', '#92400e');
      return;
    }

    const res  = await fetch(`/bookings/check-availability?homeId=${HOME_ID}&checkIn=${checkIn}&checkOut=${checkOut}`);
    const data = await res.json();

    if (data.available) {
      _nights = data.nights;
      _total  = data.totalPrice;
      document.getElementById('nightsLabel').textContent = `₹${data.pricePerNight} × ${data.nights} nights`;
      document.getElementById('nightsTotal').textContent = `₹${data.totalPrice}`;
      document.getElementById('grandTotal').textContent  = `₹${data.totalPrice}`;
      document.getElementById('payAmount').textContent   = data.totalPrice;
      priceBox.style.display = 'block';
      bookBtn.style.display  = 'block';
      showResult('✓ Available for your dates!', '#dcfce7', '#166534');
    } else {
      priceBox.style.display = 'none';
      bookBtn.style.display  = 'none';
      showResult('✗ Not available for these dates. Please try different dates.', '#fee2e2', '#991b1b');
    }
  }

  function showResult(msg, bg, color) {
    const el = document.getElementById('availResult');
    el.style.display    = 'block';
    el.style.background = bg;
    el.style.color      = color;
    el.textContent      = msg;
  }

  async function startPayment() {
    if (!IS_LOGGED) {
      window.location.href = '/login';
      return;
    }

    const checkIn  = document.getElementById('checkIn').value;
    const checkOut = document.getElementById('checkOut').value;
    const guests   = document.getElementById('guestsSelect').value;

    const res  = await fetch('/bookings/create-order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': CSRF_TOKEN },
      body: JSON.stringify({ homeId: HOME_ID, checkIn, checkOut, guests })
    });
    const order = await res.json();
    if (order.error) { alert(order.error); return; }

    const options = {
      key:         order.keyId,
      amount:      order.amount,
      currency:    order.currency,
      name:        "ElevateStays",
      description: order.homeName,
      order_id:    order.orderId,
      handler: async function(response) {
        const verifyRes = await fetch('/bookings/verify-payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'CSRF-Token': CSRF_TOKEN },
          body: JSON.stringify({
              razorpay_order_id:   response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature:  response.razorpay_signature,
              homeId: HOME_ID,     // ← use the const defined at the top
              checkIn, checkOut, guests,
              totalPrice: _total,
              nights:     _nights
          })
        });
        const result = await verifyRes.json();
        if (result.success) {
          window.location.href = '/bookings/confirmation/' + result.bookingId;
        } else {
          alert('Payment verification failed. Contact support.');
        }
      },
      prefill: {
         name:  USER_NAME,
         email: USER_EMAIL
      },
      theme: { color: "#1a1a2e" }
    };

    const rzp = new Razorpay(options);
    rzp.open();
  }
  const backBtn = document.getElementById('backToHomes');
  if (backBtn) {
    const saved = sessionStorage.getItem('homeListFilters');
    if (saved) {
      backBtn.href = '/homeList?' + saved;
    }
  }
</script>
</body>
</html>