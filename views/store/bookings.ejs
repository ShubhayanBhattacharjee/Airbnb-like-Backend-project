<%- include('../partials/header', { pageTitle: "My Bookings" }) %>
<link rel="stylesheet" href="/css/bookings.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css">
</head>

<body class="bookings-body">
<%- include('../partials/navbar') %>

<main class="bookings-page">
  <section class="bookings-header">
    <div class="header-content">
      <p class="header-mini">YOUR JOURNEY</p>
      <h1>My Bookings</h1>
      <p class="header-sub">Every stay you've reserved, all in one place.</p>
    </div>
    <a href="/homeList" class="explore-btn">
      <i class="ri-compass-3-line"></i>
      Explore more homes
    </a>
  </section>

  <section class="bookings-tabs">
    <button class="tab-btn active" data-tab="upcoming">
      <i class="ri-calendar-check-line"></i>
      Upcoming
    </button>
    <button class="tab-btn" data-tab="completed">
      <i class="ri-checkbox-circle-line"></i>
      Completed
    </button>
    <button class="tab-btn" data-tab="cancelled">
      <i class="ri-close-circle-line"></i>
      Cancelled
    </button>
  </section>

  <section class="bookings-list">

    <% if (!bookings || bookings.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">
          <i class="ri-hotel-bed-line"></i>
        </div>
        <h2>No bookings yet</h2>
        <p>You haven't reserved any homes. Start exploring to find your perfect stay.</p>
        <a href="/homeList" class="empty-btn">
          Browse Homes
          <i class="ri-arrow-right-line"></i>
        </a>
      </div>
    <% } else { %>
      <% bookings.forEach(booking => { %>
        <div class="booking-card" data-status="<%= booking.status %>">
          <div class="booking-image">
            <img src="<%= booking.home.photo %>" alt="<%= booking.home.houseName %>">
            <span class="status-badge status-<%= booking.status %>">
              <% if (booking.status === 'upcoming') { %>
                <i class="ri-calendar-2-line"></i> Upcoming
              <% } else if (booking.status === 'completed') { %>
                <i class="ri-checkbox-circle-line"></i> Completed
              <% } else { %>
                <i class="ri-close-circle-line"></i> Cancelled
              <% } %>
            </span>
          </div>
          <div class="booking-details">
            <div class="booking-top">
              <div>
                <h3><%= booking.home.houseName %></h3>
                <p class="booking-location">
                  <i class="ri-map-pin-line"></i>
                  <%= booking.home.location %>
                </p>
              </div>
              <div class="booking-price-block">
                <span class="price-total">$<%= booking.totalPrice %></span>
                <span class="price-note">total</span>
              </div>
            </div>
            <div class="booking-dates">
              <div class="date-block">
                <span class="date-label">Check-in</span>
                <span class="date-value">
                  <%= new Date(booking.checkIn).toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </span>
              </div>
              <div class="date-divider">
                <i class="ri-arrow-right-line"></i>
              </div>
              <div class="date-block">
                <span class="date-label">Check-out</span>
                <span class="date-value">
                  <%= new Date(booking.checkOut).toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </span>
              </div>
            </div>
            <div class="booking-meta">
              <div class="meta-chip">
                <i class="ri-hotel-bed-line"></i>
                <%= booking.home.no_of_bedRooms %> bedrooms
              </div>
              <div class="meta-chip">
                <i class="ri-moon-line"></i>
                <%= Math.round((new Date(booking.checkOut) - new Date(booking.checkIn)) / (1000 * 60 * 60 * 24)) %> nights
              </div>
              <div class="meta-chip">
                <i class="ri-money-dollar-circle-line"></i>
                $<%= booking.home.price %>/night
              </div>
            </div>
            <div class="booking-actions">
              <a href="/homeList/<%= booking.home._id %>" class="action-btn secondary">
                <i class="ri-eye-line"></i>
                View Home
              </a>
              <% if (booking.paymentStatus === 'paid') { %>
                <a href="/bookings/<%= booking._id %>/invoice" class="action-btn secondary" download>
                  <i class="ri-file-download-line"></i>
                  Invoice
                </a>
              <% } %>
              <% if (booking.status === 'upcoming') { %>
                <button type="button" class="action-btn secondary modify-btn"
                  data-booking-id="<%= booking._id %>"
                  data-home-id="<%= booking.home._id %>"
                  data-checkin="<%= new Date(booking.checkIn).toISOString().slice(0,10) %>"
                  data-checkout="<%= new Date(booking.checkOut).toISOString().slice(0,10) %>"
                  data-guests="<%= booking.guests %>"
                  data-max-guests="<%= booking.home.maxGuests %>"
                  data-price="<%= booking.home.price %>"
                  data-home-name="<%= booking.home.houseName %>">
                  <i class="ri-calendar-event-line"></i>
                  Modify Booking
                </button>
                <form action="/bookings/cancel/<%= booking._id %>" method="POST" style="display:inline;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="action-btn danger" onclick="return confirm('Cancel this booking?')">
                    <i class="ri-close-line"></i>
                    Cancel
                  </button>
                </form>
              <% } %>
              <% if (booking.status === 'completed' && !booking.hasReviewed) { %>
                  <button
                    class="action-btn secondary"
                    onclick="document.getElementById('reviewForm-<%= booking._id %>').style.display='block';this.style.display='none'">
                    <i class="ri-star-line"></i>
                    Leave Review
                  </button>
                  <div id="reviewForm-<%= booking._id %>" style="display:none;margin-top:12px;padding:16px;background:#f9fafb;border-radius:10px;border:1px solid #e5e7eb;">
                    <form action="/reviews/submit" method="POST">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <input type="hidden" name="bookingId" value="<%= booking._id %>">
                      <div style="margin-bottom:12px;">
                        <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:6px;">Rating</label>
                        <div class="star-picker" data-booking="<%= booking._id %>">
                          <% for(let i = 1; i <= 5; i++) { %>
                            <span class="star" data-val="<%= i %>" style="font-size:28px;cursor:pointer;color:#d1d5db;">★</span>
                          <% } %>
                        </div>
                        <input type="hidden" name="rating" id="ratingInput-<%= booking._id %>" required>
                      </div>
                      <div style="margin-bottom:12px;">
                        <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:6px;">Your experience</label>
                        <textarea
                          name="comment"
                          rows="3"
                          placeholder="Share what made this stay special (min 10 characters)..."
                          required
                          style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;resize:vertical;box-sizing:border-box;"
                        ></textarea>
                      </div>
                      <button type="submit" style="padding:8px 20px;background:#1a1a2e;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:13px;">
                        Submit Review
                      </button>
                    </form>
                  </div>
                <% } %>
                <% if (booking.status === 'completed' && booking.hasReviewed) { %>
                <% const myReview = reviewsByBooking[booking._id.toString()]; %>
                <% const canEdit = myReview && ((Date.now() - new Date(myReview.createdAt)) / (1000*60*60)) < 24; %>

                <span style="font-size:13px;color:#16a34a;">
                  <i class="ri-checkbox-circle-line"></i> Reviewed
                </span>

                <% if (canEdit) { %>
                  <!-- Edit button -->
                  <button
                    class="action-btn secondary"
                    onclick="document.getElementById('editForm-<%= booking._id %>').style.display='block';this.style.display='none'"
                    style="font-size:12px;">
                    <i class="ri-edit-line"></i> Edit
                  </button>

                  <!-- Delete button -->
                  <form action="/reviews/delete/<%= myReview._id %>" method="POST" style="display:inline;"
                    onsubmit="return confirm('Delete this review?')">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="action-btn" style="font-size:12px;background:#fee2e2;color:#991b1b;border:none;">
                      <i class="ri-delete-bin-line"></i> Delete
                    </button>
                  </form>

                  <!-- Edit form (hidden by default) -->
                  <div id="editForm-<%= booking._id %>" style="display:none;margin-top:12px;padding:16px;background:#f9fafb;border-radius:10px;border:1px solid #e5e7eb;">
                    <form action="/reviews/edit/<%= myReview._id %>" method="POST">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <div style="margin-bottom:12px;">
                        <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:6px;">Rating</label>
                        <div class="star-picker" data-booking="edit-<%= booking._id %>">
                          <% for(let i = 1; i <= 5; i++) { %>
                            <span class="star" data-val="<%= i %>"
                              style="font-size:28px;cursor:pointer;color:<%= i <= myReview.rating ? '#f59e0b' : '#d1d5db' %>;">★</span>
                          <% } %>
                        </div>
                        <input type="hidden" name="rating" id="ratingInput-edit-<%= booking._id %>" value="<%= myReview.rating %>" required>
                      </div>
                      <div style="margin-bottom:12px;">
                        <textarea name="comment" rows="3" required style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;resize:vertical;box-sizing:border-box;"><%= myReview.comment %></textarea>
                      </div>
                      <button type="submit" style="padding:8px 20px;background:#1a1a2e;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:13px;">
                        Save Changes
                      </button>
                      <button type="button"
                        onclick="document.getElementById('editForm-<%= booking._id %>').style.display='none'"
                        style="padding:8px 16px;background:#f3f4f6;color:#374151;border:none;border-radius:8px;cursor:pointer;font-size:13px;margin-left:8px;">
                        Cancel
                      </button>
                    </form>
                  </div>
                <% } else if (myReview) { %>
                  <span style="font-size:11px;color:#9ca3af;display:block;margin-top:4px;">Edit window closed (24h passed)</span>
                <% } %>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </section>

</main>
<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const cards = document.querySelectorAll('.booking-card');
  cards.forEach(card => {
    if (card.dataset.status !== 'upcoming') {
      card.style.display = 'none';
    }
  });
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const selected = tab.dataset.tab;
      cards.forEach(card => {
        if (card.dataset.status === selected) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
      const visible = [...cards].filter(c => c.style.display !== 'none');
      const empty = document.querySelector('.empty-state');
      if (empty) empty.style.display = visible.length === 0 ? 'flex' : 'none';
    });
  });
  document.querySelectorAll('.star-picker').forEach(picker => {
    const bookingId = picker.dataset.booking;
    const stars = picker.querySelectorAll('.star');
    const input = document.getElementById('ratingInput-' + bookingId);

    stars.forEach(star => {
      star.addEventListener('mouseover', () => {
        const val = parseInt(star.dataset.val);
        stars.forEach(s => {
          s.style.color = parseInt(s.dataset.val) <= val ? '#f59e0b' : '#d1d5db';
        });
      });

      star.addEventListener('mouseout', () => {
        const current = parseInt(input.value || 0);
        stars.forEach(s => {
          s.style.color = parseInt(s.dataset.val) <= current ? '#f59e0b' : '#d1d5db';
        });
      });

      star.addEventListener('click', () => {
        const val = parseInt(star.dataset.val);
        input.value = val;
        stars.forEach(s => {
          s.style.color = parseInt(s.dataset.val) <= val ? '#f59e0b' : '#d1d5db';
        });
      });
    });
  });
</script>
<div id="modifyModal" class="modify-overlay">
  <div class="modify-modal">
    <button type="button" class="modify-close-x" onclick="closeModifyModal()">&times;</button>
    <h2 class="modify-title">Edit your trip</h2>
    <p id="modifyHomeName" class="modify-subtitle"></p>

    <label class="modify-label">Dates</label>
    <div class="modify-dates-row">
      <div class="modify-date-box">
        <span class="modify-date-tag">CHECK-IN</span>
        <input type="date" id="modifyCheckIn" class="modify-date-input">
      </div>
      <div class="modify-date-box">
        <span class="modify-date-tag">CHECKOUT</span>
        <input type="date" id="modifyCheckOut" class="modify-date-input">
      </div>
    </div>
    <div id="modifyNightsBadge" class="modify-nights-badge"></div>

    <label class="modify-label" style="margin-top:18px;">Guests</label>
    <div class="guest-stepper-row">
      <div>
        <div class="guest-stepper-title">Guests</div>
        <div class="guest-stepper-note">Max <span id="guestMaxNote"></span> guests for this home</div>
      </div>
      <div class="guest-stepper">
        <button type="button" class="guest-btn" id="guestMinusBtn" onclick="changeGuests(-1)">&minus;</button>
        <span id="guestCountDisplay" class="guest-count">1</span>
        <button type="button" class="guest-btn" id="guestPlusBtn" onclick="changeGuests(1)">+</button>
      </div>
    </div>
    <input type="hidden" id="modifyGuests" value="1">

    <div id="modifyQuoteBox" class="modify-quote-box"></div>
    <div id="modifyError" class="modify-error"></div>

    <div class="modify-btn-row">
      <button type="button" id="modifyGetQuoteBtn" class="modify-btn-secondary" onclick="getModifyQuote()">
        Check Price
      </button>
      <button type="button" id="modifyConfirmBtn" class="modify-btn-primary" style="display:none;" onclick="confirmModify()">
        Confirm Change
      </button>
    </div>
    <button type="button" class="modify-cancel-link" onclick="closeModifyModal()">
      Cancel
    </button>
  </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  const CSRF_TOKEN = "<%= csrfToken %>";
  const USER_NAME  = "<%= user ? (user.fname + ' ' + user.lname) : '' %>";
  const USER_EMAIL = "<%= user ? user.email : '' %>";

  let modifyState = {};

  document.querySelectorAll('.modify-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      openModifyModal(
        btn.dataset.bookingId,
        btn.dataset.homeId,
        btn.dataset.checkin,
        btn.dataset.checkout,
        parseInt(btn.dataset.guests, 10),
        parseInt(btn.dataset.maxGuests, 10),
        parseInt(btn.dataset.price, 10),
        btn.dataset.homeName
      );
    });
  });

  function openModifyModal(bookingId, homeId, checkIn, checkOut, guests, maxGuests, pricePerNight, homeName) {
  modifyState = { bookingId, homeId, maxGuests, pricePerNight, quote: null };
  document.getElementById('modifyHomeName').textContent = homeName;

  document.getElementById('modifyCheckIn').value  = checkIn;
  document.getElementById('modifyCheckOut').value = checkOut;
  document.getElementById('modifyCheckIn').min    = new Date().toISOString().slice(0, 10);
  document.getElementById('modifyCheckOut').min   = checkIn;

  document.getElementById('modifyGuests').value = guests;
  document.getElementById('guestCountDisplay').textContent = guests;
  document.getElementById('guestMaxNote').textContent = maxGuests;
  updateGuestButtons(guests, maxGuests);

  document.getElementById('modifyQuoteBox').classList.remove('show');
  document.getElementById('modifyError').style.display = 'none';
  document.getElementById('modifyConfirmBtn').style.display = 'none';
  document.getElementById('modifyGetQuoteBtn').style.display = 'block';

  updateNightsBadge();
  document.getElementById('modifyModal').classList.add('active');
}

function closeModifyModal() {
  document.getElementById('modifyModal').classList.remove('active');
}

function updateGuestButtons(guests, maxGuests) {
  document.getElementById('guestMinusBtn').disabled = guests <= 1;
  document.getElementById('guestPlusBtn').disabled  = guests >= maxGuests;
}

function changeGuests(delta) {
  const input = document.getElementById('modifyGuests');
  let val = parseInt(input.value, 10) + delta;
  val = Math.max(1, Math.min(modifyState.maxGuests, val));
  input.value = val;
  document.getElementById('guestCountDisplay').textContent = val;
  updateGuestButtons(val, modifyState.maxGuests);
  // guests changed → any existing quote is stale
  document.getElementById('modifyQuoteBox').classList.remove('show');
  document.getElementById('modifyConfirmBtn').style.display = 'none';
}

function updateNightsBadge() {
  const checkIn  = document.getElementById('modifyCheckIn').value;
  const checkOut = document.getElementById('modifyCheckOut').value;
  const badge = document.getElementById('modifyNightsBadge');
  if (!checkIn || !checkOut) { badge.classList.remove('show'); return; }
  const nights = Math.round((new Date(checkOut) - new Date(checkIn)) / 86400000);
  if (nights > 0) {
    badge.textContent = `${nights} night${nights > 1 ? 's' : ''} selected`;
    badge.classList.add('show');
  } else {
    badge.classList.remove('show');
  }
}

document.getElementById('modifyCheckIn').addEventListener('change', function () {
  document.getElementById('modifyCheckOut').min = this.value;
  updateNightsBadge();
  document.getElementById('modifyQuoteBox').classList.remove('show');
  document.getElementById('modifyConfirmBtn').style.display = 'none';
});
document.getElementById('modifyCheckOut').addEventListener('change', function () {
  updateNightsBadge();
  document.getElementById('modifyQuoteBox').classList.remove('show');
  document.getElementById('modifyConfirmBtn').style.display = 'none';
});

  function showModifyError(msg) {
    const el = document.getElementById('modifyError');
    el.textContent = msg;
    el.style.display = 'block';
  }

  async function getModifyQuote() {
    document.getElementById('modifyError').style.display = 'none';
    const checkIn  = document.getElementById('modifyCheckIn').value;
    const checkOut = document.getElementById('modifyCheckOut').value;
    const guests   = document.getElementById('modifyGuests').value;
    if (!checkIn || !checkOut) { showModifyError('Pick both dates.'); return; }

    const res = await fetch(`/bookings/${modifyState.bookingId}/modify/quote`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': CSRF_TOKEN },
      body: JSON.stringify({ checkIn, checkOut, guests })
    });
    const data = await res.json();
    if (data.error) { showModifyError(data.error); return; }

    modifyState.quote = data;
    modifyState.checkIn = checkIn;
    modifyState.checkOut = checkOut;
    modifyState.guests = guests;

    const box = document.getElementById('modifyQuoteBox');
    let html = `${data.nights} night(s) &middot; New total: ₹${data.newTotal.toLocaleString('en-IN')}`;
    if (data.diff > 0) {
      html += `<br><strong style="color:#dc2626;">You'll pay ₹${data.diff.toLocaleString('en-IN')} more</strong>`;
    } else if (data.diff < 0) {
      html += `<br><strong style="color:#16a34a;">You'll be refunded ₹${Math.abs(data.diff).toLocaleString('en-IN')}</strong>`;
    } else {
      html += `<br><strong>No price change</strong>`;
    }
    box.innerHTML = html;
    box.classList.add('show');   
    document.getElementById('modifyConfirmBtn').style.display = 'block';
      }

  async function applyModification(paymentFields) {
    const res = await fetch(`/bookings/${modifyState.bookingId}/modify/confirm`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': CSRF_TOKEN },
      body: JSON.stringify({
        checkIn: modifyState.checkIn, checkOut: modifyState.checkOut, guests: modifyState.guests,
        ...paymentFields
      })
    });
    const data = await res.json();
    if (data.error) { showModifyError(data.error); return; }
    window.location.reload();
  }

  function confirmModify() {
    if (!modifyState.quote) return;
    if (modifyState.quote.diff > 0) {
      const options = {
        key:      modifyState.quote.keyId,
        amount:   modifyState.quote.amount,
        currency: "INR",
        name:     "HomeStays",
        description: "Trip date change — price difference",
        order_id: modifyState.quote.razorpayOrderId,
        handler: function (response) {
          applyModification({
            razorpay_order_id:   response.razorpay_order_id,
            razorpay_payment_id: response.razorpay_payment_id,
            razorpay_signature:  response.razorpay_signature
          });
        },
        prefill: { name: USER_NAME, email: USER_EMAIL },
        theme: { color: "#1a1a2e" }
      };
      const rzp = new Razorpay(options);
      rzp.open();
    } else {
      applyModification({});
    }
  }
</script>
</body>
</html>