<%- include('../partials/header', { pageTitle: "My Bookings" }) %>
<link rel="stylesheet" href="/css/bookings.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css">
</head>

<body class="bookings-body">
<%- include('../partials/navbar') %>

<main class="bookings-page">
  <section class="bookings-header">
    <div class="header-content">
      <p class="header-mini">YOUR JOURNEY</p>
      <h1>My Bookings</h1>
      <p class="header-sub">Every stay you've reserved, all in one place.</p>
    </div>
    <a href="/homeList" class="explore-btn">
      <i class="ri-compass-3-line"></i>
      Explore more homes
    </a>
  </section>

  <section class="bookings-tabs">
    <button class="tab-btn active" data-tab="upcoming">
      <i class="ri-calendar-check-line"></i>
      Upcoming
    </button>
    <button class="tab-btn" data-tab="completed">
      <i class="ri-checkbox-circle-line"></i>
      Completed
    </button>
    <button class="tab-btn" data-tab="cancelled">
      <i class="ri-close-circle-line"></i>
      Cancelled
    </button>
  </section>

  <section class="bookings-list">

    <% if (!bookings || bookings.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">
          <i class="ri-hotel-bed-line"></i>
        </div>
        <h2>No bookings yet</h2>
        <p>You haven't reserved any homes. Start exploring to find your perfect stay.</p>
        <a href="/homeList" class="empty-btn">
          Browse Homes
          <i class="ri-arrow-right-line"></i>
        </a>
      </div>
    <% } else { %>
      <% bookings.forEach(booking => { %>
        <div class="booking-card" data-status="<%= booking.status %>">
          <div class="booking-image">
            <img src="<%= booking.home.photo %>" alt="<%= booking.home.houseName %>">
            <span class="status-badge status-<%= booking.status %>">
              <% if (booking.status === 'upcoming') { %>
                <i class="ri-calendar-2-line"></i> Upcoming
              <% } else if (booking.status === 'completed') { %>
                <i class="ri-checkbox-circle-line"></i> Completed
              <% } else { %>
                <i class="ri-close-circle-line"></i> Cancelled
              <% } %>
            </span>
          </div>
          <div class="booking-details">
            <div class="booking-top">
              <div>
                <h3><%= booking.home.houseName %></h3>
                <p class="booking-location">
                  <i class="ri-map-pin-line"></i>
                  <%= booking.home.location %>
                </p>
              </div>
              <div class="booking-price-block">
                <span class="price-total">$<%= booking.totalPrice %></span>
                <span class="price-note">total</span>
              </div>
            </div>
            <div class="booking-dates">
              <div class="date-block">
                <span class="date-label">Check-in</span>
                <span class="date-value">
                  <%= new Date(booking.checkIn).toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </span>
              </div>
              <div class="date-divider">
                <i class="ri-arrow-right-line"></i>
              </div>
              <div class="date-block">
                <span class="date-label">Check-out</span>
                <span class="date-value">
                  <%= new Date(booking.checkOut).toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </span>
              </div>
            </div>
            <div class="booking-meta">
              <div class="meta-chip">
                <i class="ri-hotel-bed-line"></i>
                <%= booking.home.no_of_bedRooms %> bedrooms
              </div>
              <div class="meta-chip">
                <i class="ri-moon-line"></i>
                <%= Math.round((new Date(booking.checkOut) - new Date(booking.checkIn)) / (1000 * 60 * 60 * 24)) %> nights
              </div>
              <div class="meta-chip">
                <i class="ri-money-dollar-circle-line"></i>
                $<%= booking.home.price %>/night
              </div>
            </div>
            <div class="booking-actions">
              <a href="/homeList/<%= booking.home._id %>" class="action-btn secondary">
                <i class="ri-eye-line"></i>
                View Home
              </a>
              <% if (booking.status === 'upcoming') { %>
                <form action="/bookings/cancel/<%= booking._id %>" method="POST" style="display:inline;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="action-btn danger" onclick="return confirm('Cancel this booking?')">
                    <i class="ri-close-line"></i>
                    Cancel
                  </button>
                </form>
              <% } %>
              <% if (booking.status === 'completed' && !booking.hasReviewed) { %>
                  <button
                    class="action-btn secondary"
                    onclick="document.getElementById('reviewForm-<%= booking._id %>').style.display='block';this.style.display='none'">
                    <i class="ri-star-line"></i>
                    Leave Review
                  </button>
                  <div id="reviewForm-<%= booking._id %>" style="display:none;margin-top:12px;padding:16px;background:#f9fafb;border-radius:10px;border:1px solid #e5e7eb;">
                    <form action="/reviews/submit" method="POST">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <input type="hidden" name="bookingId" value="<%= booking._id %>">
                      <div style="margin-bottom:12px;">
                        <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:6px;">Rating</label>
                        <div class="star-picker" data-booking="<%= booking._id %>">
                          <% for(let i = 1; i <= 5; i++) { %>
                            <span class="star" data-val="<%= i %>" style="font-size:28px;cursor:pointer;color:#d1d5db;">★</span>
                          <% } %>
                        </div>
                        <input type="hidden" name="rating" id="ratingInput-<%= booking._id %>" required>
                      </div>
                      <div style="margin-bottom:12px;">
                        <label style="font-size:13px;color:#6b7280;display:block;margin-bottom:6px;">Your experience</label>
                        <textarea
                          name="comment"
                          rows="3"
                          placeholder="Share what made this stay special (min 10 characters)..."
                          required
                          style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;resize:vertical;box-sizing:border-box;"
                        ></textarea>
                      </div>
                      <button type="submit" style="padding:8px 20px;background:#1a1a2e;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:13px;">
                        Submit Review
                      </button>
                    </form>
                  </div>
                <% } %>
                <% if (booking.status === 'completed' && booking.hasReviewed) { %>
                  <span style="font-size:13px;color:#16a34a;">
                    <i class="ri-checkbox-circle-line"></i> Reviewed
                  </span>
                <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </section>

</main>
<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const cards = document.querySelectorAll('.booking-card');
  cards.forEach(card => {
    if (card.dataset.status !== 'upcoming') {
      card.style.display = 'none';
    }
  });
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const selected = tab.dataset.tab;
      cards.forEach(card => {
        if (card.dataset.status === selected) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
      const visible = [...cards].filter(c => c.style.display !== 'none');
      const empty = document.querySelector('.empty-state');
      if (empty) empty.style.display = visible.length === 0 ? 'flex' : 'none';
    });
  });
  document.querySelectorAll('.star-picker').forEach(picker => {
    const bookingId = picker.dataset.booking;
    const stars = picker.querySelectorAll('.star');
    const input = document.getElementById('ratingInput-' + bookingId);

    stars.forEach(star => {
      star.addEventListener('mouseover', () => {
        const val = parseInt(star.dataset.val);
        stars.forEach(s => {
          s.style.color = parseInt(s.dataset.val) <= val ? '#f59e0b' : '#d1d5db';
        });
      });

      star.addEventListener('mouseout', () => {
        const current = parseInt(input.value || 0);
        stars.forEach(s => {
          s.style.color = parseInt(s.dataset.val) <= current ? '#f59e0b' : '#d1d5db';
        });
      });

      star.addEventListener('click', () => {
        const val = parseInt(star.dataset.val);
        input.value = val;
        stars.forEach(s => {
          s.style.color = parseInt(s.dataset.val) <= val ? '#f59e0b' : '#d1d5db';
        });
      });
    });
  });
</script>
</body>
</html>