<%- include('../partials/header', { pageTitle: "Your Listings" }) %>
<link rel="stylesheet" href="/css/hostHomeList.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css">
</head>

<body class="host-listings-body">
<%- include('../partials/navbar') %>

<main class="host-listings-page">

  <!-- HERO BANNER -->
  <section class="listings-hero">
    <div class="hero-overlay"></div>
    <div class="hero-gradient"></div>
    <div class="hero-content">
      <div class="hero-text">
        <p class="hero-mini">YOUR PORTFOLIO</p>
        <h1>
          Your listed
          <span>properties.</span>
        </h1>
        <p class="hero-description">
          Manage, edit, and track all the homes you've listed on Nestora.
          Every stay starts here.
        </p>
      </div>
      <a href="/host/addHome" class="add-listing-btn">
        <i class="ri-add-circle-line"></i>
        Add new listing
      </a>
    </div>
  </section>

  <!-- LISTINGS SECTION -->
  <section class="listings-section">

    <div class="listings-topbar">
      <p><%= registeredHomes.length %> listing<%= registeredHomes.length !== 1 ? 's' : '' %></p>
      <a href="/host/addHome" class="topbar-add-btn">
        <i class="ri-add-line"></i>
        New listing
      </a>
    </div>

    <% if (registeredHomes.length === 0) { %>

      <!-- EMPTY STATE -->
      <div class="empty-state">
        <div class="empty-icon">
          <i class="ri-home-3-line"></i>
        </div>
        <h2>No listings yet</h2>
        <p>You haven't listed any homes. Add your first property to start hosting guests.</p>
        <a href="/host/addHome" class="empty-btn">
          List your first home
          <i class="ri-arrow-right-line"></i>
        </a>
      </div>

    <% } else { %>

      <div class="listings-grid">
        <% registeredHomes.forEach(home => { %>

          <div class="listing-card">

            <!-- IMAGE -->
            <div class="listing-image">
              <img src="/<%= home.photo %>" alt="<%= home.houseName %>">
              <div class="listing-image-overlay">
                <a href="/host/editHome/<%= home._id %>?editing=true" class="overlay-btn">
                  <i class="ri-edit-line"></i>
                </a>
              </div>
              <span class="listing-badge">
                <i class="ri-checkbox-circle-fill"></i>
                Live
              </span>
            </div>

            <!-- CONTENT -->
            <div class="listing-content">
              <div class="listing-top">
                <h3><%= home.houseName %></h3>
                <div class="listing-price">
                  ₹<%= home.price %>
                  <span>/ night</span>
                </div>
              </div>

              <p class="listing-location">
                <i class="ri-map-pin-line"></i>
                <%= home.location %>
              </p>

              <div class="listing-chips">
                <span class="chip">
                  <i class="ri-hotel-bed-line"></i>
                  <%= home.no_of_bedRooms %> bedroom<%= home.no_of_bedRooms > 1 ? 's' : '' %>
                </span>
                <span class="chip">
                  <i class="ri-home-4-line"></i>
                  Entire home
                </span>
              </div>

              <% if (home.description) { %>
                <p class="listing-desc"><%= home.description.length > 100 ? home.description.substring(0, 100) + '…' : home.description %></p>
              <% } %>

              <!-- ACTIONS -->
              <div class="listing-actions">
                <a href="/host/editHome/<%= home._id %>?editing=true" class="action-btn edit-btn">
                  <i class="ri-edit-line"></i>
                  Edit
                </a>
                <form action="/host/deleteHome/<%= home._id %>" method="POST" style="display:inline;">
                  <input
                      type="hidden"
                      name="_csrf"
                      value="<%= csrfToken %>"
                  >

                  <button
                    type="submit"
                    class="action-btn delete-btn"
                    onclick="return confirm('Delete \'<%= home.houseName %>\'? This cannot be undone.')"
                  >
                    <i class="ri-delete-bin-line"></i>
                    Delete
                  </button>
                </form>
              </div>
            </div>

          </div>

        <% }) %>
      </div>

    <% } %>

  </section>

</main>

</body>
</html>