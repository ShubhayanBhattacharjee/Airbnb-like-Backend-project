<%- include('../partials/header', { pageTitle: "Host Dashboard" }) %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css">
<style>
  .badge-upcoming  { background:#dcfce7; color:#166534; }
  .badge-cancelled { background:#fee2e2; color:#991b1b; }
  .badge-completed { background:#f3f4f6; color:#374151; }
</style>
</head>

<body>
<%- include('../partials/navbar') %>

<main style="max-width:1000px;margin:60px auto;padding:24px;">

  <!-- HEADER -->
  <div style="margin-bottom:32px;">
    <p style="font-size:12px;color:#9ca3af;text-transform:uppercase;letter-spacing:1px;margin:0;">HOST DASHBOARD</p>
    <h1 style="margin:4px 0 4px;font-size:28px;">Welcome back, <%= user.fname %></h1>
    <p style="color:#6b7280;margin:0;font-size:14px;">Here's how your properties are performing.</p>
  </div>

  <!-- STAT CARDS -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px;">

    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:20px;">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div>
          <p style="margin:0 0 6px;font-size:13px;color:#6b7280;">Total Revenue</p>
          <p style="margin:0;font-size:26px;font-weight:700;color:#166534;">₹<%= stats.totalRevenue.toLocaleString('en-IN') %></p>
        </div>
        <div style="background:#dcfce7;padding:10px;border-radius:10px;">
          <i class="ri-money-rupee-circle-line" style="font-size:20px;color:#16a34a;"></i>
        </div>
      </div>
      <p style="margin:12px 0 0;font-size:12px;color:#9ca3af;">From all paid bookings</p>
    </div>

    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:20px;">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div>
          <p style="margin:0 0 6px;font-size:13px;color:#6b7280;">Total Bookings</p>
          <p style="margin:0;font-size:26px;font-weight:700;color:#1a1a2e;"><%= stats.totalBookings %></p>
        </div>
        <div style="background:#e0e7ff;padding:10px;border-radius:10px;">
          <i class="ri-calendar-check-line" style="font-size:20px;color:#4f46e5;"></i>
        </div>
      </div>
      <p style="margin:12px 0 0;font-size:12px;color:#9ca3af;">
        <span style="color:#16a34a;font-weight:500;"><%= stats.upcomingBookings %> upcoming</span>
        · <%= stats.completedBookings %> completed
      </p>
    </div>

    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:20px;">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div>
          <p style="margin:0 0 6px;font-size:13px;color:#6b7280;">Avg Rating</p>
          <p style="margin:0;font-size:26px;font-weight:700;color:#1a1a2e;">
            <%= stats.avgRating || '—' %>
            <% if (stats.avgRating) { %><span style="font-size:16px;color:#f59e0b;">★</span><% } %>
          </p>
        </div>
        <div style="background:#fef3c7;padding:10px;border-radius:10px;">
          <i class="ri-star-line" style="font-size:20px;color:#f59e0b;"></i>
        </div>
      </div>
      <p style="margin:12px 0 0;font-size:12px;color:#9ca3af;"><%= stats.totalReviews %> review<%= stats.totalReviews !== 1 ? 's' : '' %> across all listings</p>
    </div>

  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:32px;">

    <!-- MONTHLY CHART -->
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;">
      <h2 style="margin:0 0 20px;font-size:16px;">Bookings — Last 6 Months</h2>
      <% if (monthlyData.length === 0) { %>
        <p style="color:#9ca3af;font-size:14px;">No booking data yet.</p>
      <% } else { %>
        <% const maxBookings = Math.max(...monthlyData.map(m => m.bookings)); %>
        <% monthlyData.forEach(m => { %>
        <% const barWidth = maxBookings > 0 ? Math.round((m.bookings/maxBookings)*100) : 0; %>
        <div style="margin-bottom:12px;">
            <div style="display:flex;justify-content:space-between;font-size:12px;color:#6b7280;margin-bottom:4px;">
            <span><%= m.label %></span>
            <span><%= m.bookings %> booking<%= m.bookings !== 1 ? 's' : '' %> · ₹<%= m.revenue.toLocaleString('en-IN') %></span>
            </div>
            <div style="background:#f3f4f6;border-radius:99px;height:8px;">
                <div style="background:#1a1a2e;border-radius:99px;height:8px;" data-width="<%= barWidth %>"></div>
            </div>
            </div>
        </div>
        <% }) %>
      <% } %>
    </div>

    <!-- MOST BOOKED + LISTINGS SUMMARY -->
    <div style="display:flex;flex-direction:column;gap:16px;">

      <!-- Most Booked -->
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:20px;">
        <h2 style="margin:0 0 14px;font-size:16px;">Most Booked Listing</h2>
        <% if (!mostBooked) { %>
          <p style="color:#9ca3af;font-size:14px;">No bookings yet.</p>
        <% } else { %>
          <div style="display:flex;gap:12px;align-items:center;">
            <img src="<%= mostBooked.home.photo %>" style="width:60px;height:60px;border-radius:10px;object-fit:cover;">
            <div>
              <p style="margin:0;font-weight:600;font-size:14px;"><%= mostBooked.home.houseName %></p>
              <p style="margin:2px 0 0;font-size:13px;color:#6b7280;"><%= mostBooked.count %> bookings · ₹<%= mostBooked.revenue.toLocaleString('en-IN') %> earned</p>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Listings Summary -->
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:20px;">
        <h2 style="margin:0 0 14px;font-size:16px;">Your Listings (<%= homes.length %>)</h2>
        <% homes.forEach(h => { %>
          <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid #f3f4f6;">
            <div style="display:flex;gap:10px;align-items:center;">
              <img src="<%= h.photo %>" style="width:36px;height:36px;border-radius:8px;object-fit:cover;">
              <div>
                <p style="margin:0;font-size:13px;font-weight:500;"><%= h.houseName %></p>
                <p style="margin:0;font-size:12px;color:#9ca3af;">₹<%= h.price %>/night</p>
              </div>
            </div>
            <a href="/host/manage-dates/<%= h._id %>" style="font-size:12px;color:#4f46e5;text-decoration:none;">Manage →</a>
          </div>
        <% }) %>
      </div>

    </div>
  </div>

  <!-- RECENT BOOKINGS -->
  <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
      <h2 style="margin:0;font-size:16px;">Recent Bookings</h2>
      <a href="/host/hostHomeList" style="font-size:13px;color:#4f46e5;text-decoration:none;">View all listings →</a>
    </div>
    <% if (recentBookings.length === 0) { %>
      <p style="color:#9ca3af;font-size:14px;">No bookings yet.</p>
    <% } else { %>
      <% recentBookings.forEach(b => { %>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #f3f4f6;">
          <div style="display:flex;gap:12px;align-items:center;">
            <img src="<%= b.guest.profileImage %>" style="width:36px;height:36px;border-radius:50%;object-fit:cover;">
            <div>
              <p style="margin:0;font-size:13px;font-weight:500;"><%= b.guest.fname %> <%= b.guest.lname %></p>
              <p style="margin:0;font-size:12px;color:#6b7280;">
                <%= b.home.houseName %> ·
                <%= new Date(b.checkIn).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %> →
                <%= new Date(b.checkOut).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
              </p>
            </div>
          </div>
          <div style="text-align:right;">
            <p style="margin:0;font-size:13px;font-weight:600;">₹<%= b.totalPrice.toLocaleString('en-IN') %></p>
            <span style="font-size:11px;padding:2px 8px;border-radius:20px;font-weight:500;"
                class="badge-<%= b.status %>">
            <%= b.status %>
            </span>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

</main>
<script>
  document.querySelectorAll('[data-width]').forEach(el => {
    el.style.width = el.dataset.width + '%';
  });
</script>
</body>
</html>