<%- include('../partials/header', { pageTitle: pageTitle }) %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.min.css">
</head>
<body>
<%- include('../partials/navbar') %>

<main style="max-width:1000px;margin:60px auto;padding:24px;">
  <a href="/host/hostHomeList" style="color:#6b7280;text-decoration:none;font-size:14px;">← Back to Listings</a>
  <h1 style="margin:16px 0 4px;"><%= home.houseName %></h1>
  <p style="color:#6b7280;margin:0 0 32px;">Performance over time for this listing</p>

  <!-- STAT CARDS -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px;">
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:20px;">
      <p style="margin:0 0 6px;font-size:13px;color:#6b7280;">Total Revenue</p>
      <p style="margin:0;font-size:22px;font-weight:700;color:#166534;">₹<%= totalRevenue.toLocaleString('en-IN') %></p>
    </div>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:20px;">
      <p style="margin:0 0 6px;font-size:13px;color:#6b7280;">Total Bookings</p>
      <p style="margin:0;font-size:22px;font-weight:700;color:#1a1a2e;"><%= totalBookings %></p>
    </div>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:20px;">
      <p style="margin:0 0 6px;font-size:13px;color:#6b7280;">Upcoming / Completed</p>
      <p style="margin:0;font-size:22px;font-weight:700;color:#1a1a2e;"><%= upcomingCount %> / <%= completedCount %></p>
    </div>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:20px;">
      <p style="margin:0 0 6px;font-size:13px;color:#6b7280;">Rating</p>
      <p style="margin:0;font-size:22px;font-weight:700;color:#1a1a2e;">
        <%= home.avgRating || '—' %>
        <% if (home.avgRating) { %><span style="font-size:14px;color:#f59e0b;">★</span><% } %>
      </p>
      <p style="margin:6px 0 0;font-size:11px;color:#9ca3af;"><%= home.reviewCount %> review<%= home.reviewCount !== 1 ? 's' : '' %></p>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">

    <!-- REVENUE / BOOKINGS TREND -->
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;">
      <h2 style="margin:0 0 20px;font-size:16px;">Bookings & Revenue — Last 6 Months</h2>
      <% if (monthlyData.length === 0) { %>
        <p style="color:#9ca3af;font-size:14px;">No booking data yet for this listing.</p>
      <% } else { %>
        <% const maxBookings = Math.max(...monthlyData.map(m => m.bookings)); %>
        <% monthlyData.forEach(m => { %>
          <% const barWidth = maxBookings > 0 ? Math.round((m.bookings / maxBookings) * 100) : 0; %>
          <div style="margin-bottom:12px;">
            <div style="display:flex;justify-content:space-between;font-size:12px;color:#6b7280;margin-bottom:4px;">
              <span><%= m.label %></span>
              <span><%= m.bookings %> booking<%= m.bookings !== 1 ? 's' : '' %> · ₹<%= m.revenue.toLocaleString('en-IN') %></span>
            </div>
            <div style="background:#f3f4f6;border-radius:99px;height:8px;">
              <div style="background:#1a1a2e;border-radius:99px;height:8px;" data-width="<%= barWidth %>"></div>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <!-- OCCUPANCY TREND -->
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;">
      <h2 style="margin:0 0 20px;font-size:16px;">Occupancy Rate — Last 6 Months</h2>
      <% occupancyData.forEach(o => { %>
        <div style="margin-bottom:12px;">
          <div style="display:flex;justify-content:space-between;font-size:12px;color:#6b7280;margin-bottom:4px;">
            <span><%= o.label %></span>
            <span><%= o.occupancyPercent %>% booked</span>
          </div>
          <div style="background:#f3f4f6;border-radius:99px;height:8px;">
            <div style="background:#C9A96E;border-radius:99px;height:8px;" data-width="<%= o.occupancyPercent %>"></div>
          </div>
        </div>
      <% }) %>
      <p style="margin:16px 0 0;font-size:11px;color:#9ca3af;">Based on nights booked ÷ days in each month.</p>
    </div>

  </div>
</main>
<script>
  document.querySelectorAll('[data-width]').forEach(el => {
    el.style.width = el.dataset.width + '%';
  });
</script>
</body>
</html>