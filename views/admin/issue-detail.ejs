<%- include("../partials/header", { pageTitle: "Issue detail" }) %>
<link rel="stylesheet" href="/css/admin/admin.css">
</head>
<body>
<nav class="sidebar">
    <h1><span>●</span> Ops Console</h1>
    <a href="/admin/dashboard">Dashboard</a>
    <a href="/admin/users">Users</a>
    <a href="/admin/listings">Listings</a>
    <a href="/admin/bookings">Bookings</a>
    <a href="/admin/payouts">Payouts</a>
    <a href="/admin/reviews">Reviews</a>
    <a href="/admin/issues" class="active">Issues</a>
    <a href="/admin/auditLog">Audit Log</a>
    <form method="POST" action="/admin/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button>Sign out</button>
    </form>
  </nav>

<div class="main">
    <a href="/admin/issues" class="btn-secondary" style="margin-bottom:20px;display:inline-block;">← Back to issues</a>

    <div class="issue-detail-grid">
        <div class="chart-card">
            <h2>Issue details</h2>
            <div class="notfound-readout">
                <div class="readout-row"><span class="k">Role</span><span class="badge badge-role-<%= issue.role %>"><%= issue.role %></span></div>
                <div class="readout-row"><span class="k">Name</span><span class="v"><%= issue.name %></span></div>
                <div class="readout-row"><span class="k">Email</span><span class="v"><%= issue.email %></span></div>
                <% if (issue.bookingId) { %>
                    <div class="readout-row"><span class="k">Booking</span><span class="v"><%= issue.bookingId._id || issue.bookingId %></span></div>
                <% } %>
                <% if (issue.propertyId) { %>
                    <div class="readout-row"><span class="k">Property</span><span class="v"><%= issue.propertyId.title || issue.propertyId %></span></div>
                <% } %>
                <div class="readout-row"><span class="k">Type</span><span class="v"><%= issue.issueType %></span></div>
                <div class="readout-row"><span class="k">Received</span><span class="v"><%= new Date(issue.createdAt).toLocaleString() %></span></div>
                <div class="readout-row"><span class="k">Status</span><span class="badge badge-issue-<%= issue.status %>"><%= issue.status.replace('_', ' ') %></span></div>
            </div>

            <h3>Subject</h3>
            <p><%= issue.subject %></p>

            <h3>Message</h3>
            <p style="white-space:pre-wrap;color:var(--text-dim);"><%= issue.message %></p>

            <% if (issue.resolution && issue.resolution.resolvedAt) { %>
                <h3>Resolution</h3>
                <p style="color:var(--good);"><%= issue.resolution.note %></p>
                <p class="reason-note">Resolved <%= new Date(issue.resolution.resolvedAt).toLocaleString() %></p>
            <% } %>
        </div>

        <div class="chart-card">
            <h2>Update status</h2>
            <form method="POST" action="/admin/issues/<%= issue._id %>/status">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="form-group">
                    <label>Status</label>
                    <select name="status" required>
                        <option value="open" <%= issue.status === 'open' ? 'selected' : '' %>>Open</option>
                        <option value="in_progress" <%= issue.status === 'in_progress' ? 'selected' : '' %>>In progress</option>
                        <option value="resolved" <%= issue.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
                        <option value="closed" <%= issue.status === 'closed' ? 'selected' : '' %>>Closed</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Resolution note <span class="optional-tag">(internal)</span></label>
                    <textarea name="resolution_note" placeholder="What was done to fix this?"><%= issue.resolution ? issue.resolution.note : '' %></textarea>
                </div>
                <button type="submit" class="btn-primary">Save</button>
            </form>
        </div>
    </div>
</div>
</body>
</html>