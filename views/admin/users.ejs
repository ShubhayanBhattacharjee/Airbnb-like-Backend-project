<!DOCTYPE html>
<html>
<head>
  <title><%= pageTitle %></title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:sans-serif;display:flex;min-height:100vh;background:#f9fafb}
    .sidebar{width:220px;background:#1a1a2e;color:#fff;padding:24px 16px;flex-shrink:0;display:flex;flex-direction:column}
    .sidebar h1{font-size:16px;margin-bottom:32px;opacity:.8}
    .sidebar a{display:block;color:#cbd5e1;text-decoration:none;padding:10px 12px;border-radius:8px;font-size:14px;margin-bottom:4px}
    .sidebar a:hover{background:rgba(255,255,255,.1);color:#fff}
    .sidebar a.active{background:rgba(255,255,255,.1);color:#fff}
    .main{flex:1;padding:32px;overflow:auto}
    .admin-table{width:100%;border-collapse:collapse;font-size:13px;margin-top:12px}
    .admin-table th{background:#f3f4f6;padding:10px 12px;text-align:left;font-weight:600;color:#374151}
    .admin-table td{padding:10px 12px;border-bottom:1px solid #f3f4f6;color:#4b5563;vertical-align:middle}
    .btn-danger{padding:4px 10px;background:#fee2e2;color:#dc2626;border:none;border-radius:6px;cursor:pointer;font-size:12px}
    .btn-success{padding:4px 10px;background:#dcfce7;color:#16a34a;border:none;border-radius:6px;cursor:pointer;font-size:12px}
    .btn-secondary{padding:4px 10px;background:#f3f4f6;color:#374151;border:none;border-radius:6px;cursor:pointer;font-size:12px}
    .badge{display:inline-block;padding:2px 8px;border-radius:12px;font-size:11px;font-weight:600}
    .badge-hidden{background:#fee2e2;color:#dc2626}
    .badge-ok{background:#dcfce7;color:#16a34a}
    .pagination{display:flex;gap:8px;margin-top:24px;flex-wrap:wrap;align-items:center}
    .pagination a{padding:6px 12px;border:1px solid #e5e7eb;border-radius:8px;font-size:13px;color:#374151;text-decoration:none;background:#fff}
    .pagination a.active{background:#1a1a2e;color:#fff;border-color:#1a1a2e}
    h2{font-size:22px;color:#1a1a2e;margin-bottom:20px}
  </style>
</head>
<body>
  <nav class="sidebar">
    <h1>🛡 Admin Panel</h1>
    <a href="/admin/dashboard">📊 Dashboard</a>
    <a href="/admin/users" class="active">👥 Users</a>
    <a href="/admin/listings">🏠 Listings</a>
    <a href="/admin/bookings">📅 Bookings</a>
    <a href="/admin/payouts">💸 Payouts</a>
    <a href="/admin/reviews">⭐ Reviews</a>
    <form method="POST" action="/admin/logout" style="margin-top:auto;padding-top:32px;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button style="width:100%;padding:10px;background:rgba(255,255,255,.1);color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:13px;">Logout</button>
    </form>
  </nav>

  <div class="main">
    <h2>Manage Users</h2>

    <form method="GET" style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
      <input name="search" value="<%= filters.search %>" placeholder="Search name or email" style="padding:8px 12px;border:1px solid #e5e7eb;border-radius:8px;font-size:13px;">
      <select name="role" style="padding:8px;border:1px solid #e5e7eb;border-radius:8px;font-size:13px;">
        <option value="all" <%= filters.role === 'all' ? 'selected' : '' %>>All roles</option>
        <option value="guest" <%= filters.role === 'guest' ? 'selected' : '' %>>Guests</option>
        <option value="host" <%= filters.role === 'host' ? 'selected' : '' %>>Hosts</option>
      </select>
      <select name="banned" style="padding:8px;border:1px solid #e5e7eb;border-radius:8px;font-size:13px;">
        <option value="">All</option>
        <option value="true" <%= filters.banned === 'true' ? 'selected' : '' %>>Banned only</option>
      </select>
      <button type="submit" style="padding:8px 16px;background:#1a1a2e;color:#fff;border:none;border-radius:8px;cursor:pointer;">Filter</button>
    </form>

    <p style="font-size:13px;color:#6b7280;margin-bottom:12px;"><strong><%= total %></strong> user(s) found</p>

    <table class="admin-table">
      <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>
      <% users.forEach(u => { %>
        <tr>
          <td><%= u.fname %> <%= u.lname %></td>
          <td><%= u.email %></td>
          <td><%= u.role %></td>
          <td>
            <% if (u.isBanned) { %>
              <span class="badge badge-hidden">Banned</span><br>
              <span style="font-size:11px;color:#9ca3af;"><%= u.banReason %></span>
            <% } else { %>
              <span class="badge badge-ok">Active</span>
            <% } %>
          </td>
          <td style="display:flex;gap:6px;flex-wrap:wrap;">
            <% if (!u.isBanned) { %>
              <form method="POST" action="/admin/users/<%= u._id %>/ban">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input name="reason" placeholder="Ban reason" style="padding:4px 8px;font-size:12px;border:1px solid #e5e7eb;border-radius:6px;">
                <button class="btn-danger" type="submit">Ban</button>
              </form>
            <% } else { %>
              <form method="POST" action="/admin/users/<%= u._id %>/unban">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn-success" type="submit">Unban</button>
              </form>
            <% } %>
            <form method="POST" action="/admin/users/<%= u._id %>/change-role">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <select name="role" style="font-size:12px;padding:4px;border:1px solid #e5e7eb;border-radius:6px;">
                <option value="guest" <%= u.role === 'guest' ? 'selected' : '' %>>guest</option>
                <option value="host"  <%= u.role === 'host'  ? 'selected' : '' %>>host</option>
              </select>
              <button class="btn-secondary" type="submit">Change</button>
            </form>
            <form method="POST" action="/admin/users/<%= u._id %>/delete" onsubmit="return confirm('Delete this user and all their data?')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn-danger" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>

    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %>
          <a href="/admin/users?page=<%= page - 1 %>&search=<%= filters.search %>&role=<%= filters.role %>&banned=<%= filters.banned %>">← Prev</a>
        <% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="/admin/users?page=<%= i %>&search=<%= filters.search %>&role=<%= filters.role %>&banned=<%= filters.banned %>"
            class="<%= i === page ? 'active' : '' %>"><%= i %></a>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="/admin/users?page=<%= page + 1 %>&search=<%= filters.search %>&role=<%= filters.role %>&banned=<%= filters.banned %>">Next →</a>
        <% } %>
      </div>
      <p style="font-size:13px;color:#9ca3af;margin-top:8px;">Page <%= page %> of <%= totalPages %></p>
    <% } %>
  </div>
</body>
</html>