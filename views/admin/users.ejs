<!DOCTYPE html>
<html>
<head>
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/admin/admin.css">
</head>
<body>
  <nav class="sidebar">
    <h1><span>●</span> Ops Console</h1>
    <a href="/admin/dashboard">Dashboard</a>
    <a href="/admin/users" class="active">Users</a>
    <a href="/admin/listings">Listings</a>
    <a href="/admin/bookings">Bookings</a>
    <a href="/admin/payouts">Payouts</a>
    <a href="/admin/reviews">Reviews</a>
    <a href="/admin/issues">Issues</a>
    <a href="/admin/auditLog">Audit Log</a>
    <form method="POST" action="/admin/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button>Sign out</button>
    </form>
  </nav>

  <div class="main">
    <div class="status-strip">
      <span class="pulse-dot"></span>
      <span>Live</span>
      <span class="dim">·</span>
      <span><%= new Date().toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
    </div>
    <h2>Manage Users</h2>

    <form method="GET" class="filter-bar">
      <input name="search" value="<%= filters.search %>" placeholder="Search name or email">
      <select name="role">
        <option value="all" <%= filters.role === 'all' ? 'selected' : '' %>>All roles</option>
        <option value="guest" <%= filters.role === 'guest' ? 'selected' : '' %>>Guests</option>
        <option value="host" <%= filters.role === 'host' ? 'selected' : '' %>>Hosts</option>
      </select>
      <select name="banned">
        <option value="">All</option>
        <option value="true" <%= filters.banned === 'true' ? 'selected' : '' %>>Banned only</option>
      </select>
      <button type="submit" class="btn-export-primary">Filter</button>
    </form>

    <p class="result-count"><strong><%= total %></strong> user(s) found</p>

    <table class="admin-table">
      <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>
      <% users.forEach(u => { %>
        <tr>
          <td><%= u.fname %> <%= u.lname %></td>
          <td class="num"><%= u.email %></td>
          <td><%= u.role %></td>
          <td>
            <% if (u.isBanned) { %>
              <span class="badge badge-hidden">Banned</span>
              <span class="reason-note"><%= u.banReason %></span>
            <% } else { %>
              <span class="badge badge-ok">Active</span>
            <% } %>
          </td>
          <td>
            <div class="row-actions">
              <% if (!u.isBanned) { %>
                <form method="POST" action="/admin/users/<%= u._id %>/ban" class="row-actions">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input name="reason" placeholder="Ban reason">
                  <button class="btn-danger" type="submit">Ban</button>
                </form>
              <% } else { %>
                <form method="POST" action="/admin/users/<%= u._id %>/unban">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn-success" type="submit">Unban</button>
                </form>
              <% } %>
              <form method="POST" action="/admin/users/<%= u._id %>/change-role" class="row-actions">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <select name="role">
                  <option value="guest" <%= u.role === 'guest' ? 'selected' : '' %>>guest</option>
                  <option value="host"  <%= u.role === 'host'  ? 'selected' : '' %>>host</option>
                </select>
                <button class="btn-secondary" type="submit">Change</button>
              </form>
              <form method="POST" action="/admin/users/<%= u._id %>/delete" onsubmit="return confirm('Delete this user and all their data?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn-danger" type="submit">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>

    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %>
          <a href="/admin/users?page=<%= page - 1 %>&search=<%= filters.search %>&role=<%= filters.role %>&banned=<%= filters.banned %>">← Prev</a>
        <% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="/admin/users?page=<%= i %>&search=<%= filters.search %>&role=<%= filters.role %>&banned=<%= filters.banned %>"
            class="<%= i === page ? 'active' : '' %>"><%= i %></a>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="/admin/users?page=<%= page + 1 %>&search=<%= filters.search %>&role=<%= filters.role %>&banned=<%= filters.banned %>">Next →</a>
        <% } %>
      </div>
      <p style="font-size:12.5px;color:var(--text-faint);margin-top:8px;">Page <%= page %> of <%= totalPages %></p>
    <% } %>
  </div>
</body>
</html>