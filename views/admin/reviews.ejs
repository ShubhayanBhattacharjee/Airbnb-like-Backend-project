<!DOCTYPE html>
<html>
<head>
  <title>Manage Reviews</title>
  <link rel="stylesheet" href="/css/admin/admin.css">
</head>
<body>
  <nav class="sidebar">
    <h1><span>●</span> Ops Console</h1>
    <a href="/admin/dashboard">Dashboard</a>
    <a href="/admin/users">Users</a>
    <a href="/admin/listings">Listings</a>
    <a href="/admin/bookings">Bookings</a>
    <a href="/admin/payouts">Payouts</a>
    <a href="/admin/reviews" class="active">Reviews</a>
    <a href="/admin/issues">Issues</a>
    <a href="/admin/auditLog">Audit Log</a>
    <form method="POST" action="/admin/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button>Logout</button>
    </form>
  </nav>

  <div class="main">
    <div class="status-strip">
      <span class="pulse-dot"></span>
      <span>Live</span>
      <span class="dim">·</span>
      <span><%= new Date().toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
    </div>
    <h2>Manage Reviews</h2>

    <form method="GET" class="filter-bar">
      <select name="flagged">
        <option value="">All reviews</option>
        <option value="true" <%= filters.flagged === 'true' ? 'selected' : '' %>>Flagged only</option>
      </select>
      <button type="submit" class="btn-export-primary">Filter</button>
    </form>

    <p class="result-count"><strong><%= total %></strong> review(s) found</p>

    <table class="admin-table">
      <thead>
        <tr>
          <th>Guest</th>
          <th>Home</th>
          <th>Rating</th>
          <th>Comment</th>
          <th>Date</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% reviews.forEach(r => { %>
        <tr>
          <td>
            <%= r.guest?.fname %> <%= r.guest?.lname %><br>
            <span class="review-guest-email"><%= r.guest?.email %></span>
          </td>
          <td><%= r.home?.houseName %></td>
          <td>
            <span class="stars"><%= '★'.repeat(r.rating) %><%= '☆'.repeat(5 - r.rating) %></span>
          </td>
          <td class="review-comment"><%= r.comment.substring(0, 80) %><%= r.comment.length > 80 ? '...' : '' %></td>
          <td class="num"><%= new Date(r.createdAt).toLocaleDateString('en-IN') %></td>
          <td>
            <% if (r.isFlagged) { %>
              <span class="badge badge-flag">Flagged</span>
              <span class="reason-note"><%= r.flagReason %></span>
            <% } else { %>
              <span class="badge badge-ok">OK</span>
            <% } %>
          </td>
          <td>
            <div class="row-actions">
              <% if (!r.isFlagged) { %>
                <form method="POST" action="/admin/reviews/<%= r._id %>/flag" style="display:flex;gap:6px;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input name="reason" placeholder="Flag reason">
                  <button class="btn-warn" type="submit">Flag</button>
                </form>
              <% } else { %>
                <form method="POST" action="/admin/reviews/<%= r._id %>/unflag">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn-success" type="submit">Unflag</button>
                </form>
              <% } %>
              <form method="POST" action="/admin/reviews/<%= r._id %>/delete"
                onsubmit="return confirm('Delete this review permanently?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn-danger" type="submit">Delete</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %>
          <a href="/admin/reviews?page=<%= page - 1 %>&flagged=<%= filters.flagged %>">← Prev</a>
        <% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="/admin/reviews?page=<%= i %>&flagged=<%= filters.flagged %>"
            class="<%= i === page ? 'active' : '' %>"><%= i %></a>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="/admin/reviews?page=<%= page + 1 %>&flagged=<%= filters.flagged %>">Next →</a>
        <% } %>
      </div>
      <p class="payout-detail-sub">Page <%= page %> of <%= totalPages %></p>
    <% } %>
  </div>
</body>
</html>