<!DOCTYPE html>
<html>
<head>
  <title>Audit Log</title>
  <link rel="stylesheet" href="/css/admin/admin.css">
</head>
<body>
  <nav class="sidebar">
    <h1><span>●</span> Ops Console</h1>
    <a href="/admin/dashboard">Dashboard</a>
    <a href="/admin/users">Users</a>
    <a href="/admin/listings">Listings</a>
    <a href="/admin/bookings">Bookings</a>
    <a href="/admin/payouts">Payouts</a>
    <a href="/admin/reviews">Reviews</a>
    <a href="/admin/auditLog" class="active">Audit Log</a>
    <form method="POST" action="/admin/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button>Logout</button>
    </form>
  </nav>

  <div class="main">
    <div class="status-strip">
      <span class="pulse-dot"></span>
      <span>Live</span>
      <span class="dim">·</span>
      <span><%= new Date().toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
    </div>
    <h2>Audit Log</h2>

    <table class="admin-table">
      <thead>
        <tr>
          <th>When</th>
          <th>Actor</th>
          <th>Action</th>
          <th>Details</th>
          <th>IP</th>
        </tr>
      </thead>
      <tbody>
        <% if (logs.length === 0) { %>
          <tr><td colspan="5" class="empty-row">No audit entries yet.</td></tr>
        <% } %>
        <% logs.forEach(log => { %>
          <% const actor = actorMap[log.actorId?.toString()]; %>
          <tr>
            <td class="nowrap"><%= new Date(log.createdAt).toLocaleString('en-IN') %></td>
            <td><%= actor ? actor.email : (log.actorType + (log.actorId ? '' : ' (system)')) %></td>
            <td><code><%= log.action %></code></td>
            <td><%= log.details %></td>
            <td class="ip"><%= log.ip %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="?page=<%= i %>" class="<%= i === page ? 'active' : '' %>"><%= i %></a>
        <% } %>
      </div>
    <% } %>
  </div>
</body>
</html>