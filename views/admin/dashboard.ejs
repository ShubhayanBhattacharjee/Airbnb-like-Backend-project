<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/admin/admin.css">
</head>
<body>
  <nav class="sidebar">
    <h1><span>●</span> Ops Console</h1>
    <a href="/admin/dashboard" class="active">Dashboard</a>
    <a href="/admin/users">Users</a>
    <a href="/admin/listings">Listings</a>
    <a href="/admin/bookings">Bookings</a>
    <a href="/admin/payouts">Payouts</a>
    <a href="/admin/reviews">Reviews</a>
    <a href="/admin/issues">Issues</a>
    <a href="/admin/auditLog">Audit Log</a>
    <form method="POST" action="/admin/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button>Sign out</button>
    </form>
  </nav>

  <div class="main">
    <div class="status-strip">
      <span class="pulse-dot"></span>
      <span>Live</span>
      <span class="dim">·</span>
      <span><%= new Date().toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
    </div>
    <h2>Dashboard</h2>

    <div class="activity-strip" aria-hidden="true">
      <% for (let i = 0; i < 48; i++) { %><span></span><% } %>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <p class="stat-num"><%= stats.totalUsers %></p>
        <p class="stat-label">Total Users</p>
      </div>
      <div class="stat-card">
        <p class="stat-num"><%= stats.totalHosts %></p>
        <p class="stat-label">Hosts</p>
      </div>
      <div class="stat-card">
        <p class="stat-num"><%= stats.totalGuests %></p>
        <p class="stat-label">Guests</p>
      </div>
      <div class="stat-card">
        <p class="stat-num"><%= stats.totalHomes %></p>
        <p class="stat-label">Listings</p>
      </div>
      <div class="stat-card">
        <p class="stat-num"><%= stats.totalBookings %></p>
        <p class="stat-label">Bookings</p>
      </div>
      <div class="stat-card">
        <p class="stat-num">₹<%= stats.revenue.toLocaleString('en-IN') %></p>
        <p class="stat-label">Total Revenue</p>
      </div>
      <div class="stat-card warn">
        <p class="stat-num"><%= stats.issuesOpen %></p>
        <p class="stat-label">Issues Opened</p>
      </div>
      <div class="stat-card warn">
        <p class="stat-num"><%= stats.auditLogs %></p>
        <p class="stat-label">Audit Logs</p>
      </div>
      <div class="stat-card danger">
        <p class="stat-num"><%= stats.bannedUsers %></p>
        <p class="stat-label">Banned Users</p>
      </div>
    </div>

    <form method="GET" action="/admin/reports/export" class="export-form">
      <select name="year">
        <option value="">All time</option>
        <% const thisYear = new Date().getFullYear(); %>
        <% for (let y = thisYear; y >= thisYear - 3; y--) { %>
          <option value="<%= y %>"><%= y %></option>
        <% } %>
      </select>
      <button type="submit" name="format" value="csv" class="btn-export-secondary">Export CSV</button>
      <button type="submit" name="format" value="pdf" class="btn-export-primary">Export PDF</button>
    </form>

    <div class="chart-card">
      <h3 style="margin-top:0">Bookings & Revenue — Last 6 Months</h3>
      <% if (monthlyData.length === 0) { %>
        <p style="font-size:13px;color:var(--text-faint);padding:40px 0;text-align:center;">Not enough booking history yet to chart.</p>
      <% } else { %>
        <div style="position:relative;height:300px;">
          <canvas id="platformChart"></canvas>
        </div>
      <% } %>
    </div>

    <h3>Recent Bookings</h3>
    <table class="admin-table">
      <thead>
        <tr><th>Guest</th><th>Home</th><th>Amount</th><th>Date</th></tr>
      </thead>
      <tbody>
        <% recentBookings.forEach(b => { %>
        <tr>
          <td><%= b.guest?.fname %> <%= b.guest?.lname %></td>
          <td><%= b.home?.houseName %></td>
          <td class="num">₹<%= b.totalPrice.toLocaleString('en-IN') %></td>
          <td class="num"><%= new Date(b.createdAt).toLocaleDateString('en-IN') %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <h3>Recent Users</h3>
    <table class="admin-table">
      <thead>
        <tr><th>Name</th><th>Email</th><th>Role</th><th>Joined</th></tr>
      </thead>
      <tbody>
        <% recentUsers.forEach(u => { %>
        <tr>
          <td><%= u.fname %> <%= u.lname %></td>
          <td class="num"><%= u.email %></td>
          <td><%= u.role %></td>
          <td class="num"><%= new Date(u._id.getTimestamp()).toLocaleDateString('en-IN') %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (monthlyData.length > 0) { %>
    <script type="application/json" id="monthly-data"><%- JSON.stringify(monthlyData) %></script>
    <script src="/js/chart.umd.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        try {
          const dataEl = document.getElementById('monthly-data');
          const canvasEl = document.getElementById('platformChart');
          if (!dataEl || !canvasEl) return;
          const monthlyData = JSON.parse(dataEl.textContent);
          if (typeof Chart === 'undefined') {
            canvasEl.insertAdjacentHTML('afterend', '<p style="color:#E5695B;font-size:13px;">Chart library failed to load — check your connection or ad-blocker.</p>');
            return;
          }
          const gridColor = 'rgba(255,255,255,.06)';
          const textColor = '#8A8D97';
          const monoFont = { family: 'JetBrains Mono', size: 11 };

          new Chart(canvasEl.getContext('2d'), {
            type: 'bar',
            data: {
              labels: monthlyData.map(m => m.label),
              datasets: [
                { label: 'Revenue (₹)', data: monthlyData.map(m => m.revenue), backgroundColor: '#FF6A1A', borderRadius: 4, yAxisID: 'y' },  
                { label: 'Bookings', data: monthlyData.map(m => m.bookings), type: 'line', borderColor: '#E5695B', backgroundColor: '#E5695B', tension: 0.3, yAxisID: 'y1' }
              ]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              interaction: { mode: 'index', intersect: false },
              plugins: { legend: { labels: { color: textColor, font: monoFont } } },
              scales: {
                x:  { ticks: { color: textColor, font: monoFont }, grid: { color: gridColor } },
                y:  { position: 'left',  beginAtZero: true, ticks: { color: textColor, font: monoFont }, grid: { color: gridColor } },
                y1: { position: 'right', beginAtZero: true, ticks: { color: textColor, font: monoFont }, grid: { drawOnChartArea: false } }
              }
            }
          });
        } catch (err) { console.error('Chart render error:', err); }
      });
    </script>
  <% } %>
</body>
</html>