<!DOCTYPE html>
<html>
<head><title>Admin Login</title>
<style>
  body{font-family:sans-serif;display:flex;justify-content:center;align-items:center;height:100vh;background:#f3f4f6;margin:0}
  .box{background:#fff;padding:40px;border-radius:12px;width:360px;box-shadow:0 4px 20px rgba(0,0,0,.08)}
  h2{margin:0 0 24px;font-size:20px;color:#1a1a2e}
  input{width:100%;padding:10px 12px;border:1px solid #e5e7eb;border-radius:8px;font-size:14px;margin-bottom:14px;box-sizing:border-box}
  button{width:100%;padding:11px;background:#1a1a2e;color:#fff;border:none;border-radius:8px;font-size:14px;cursor:pointer}
  .err{color:#dc2626;font-size:13px;margin-bottom:12px}
</style></head>
<body>
  <div class="box">
    <h2>🛡 Admin Login</h2>
    <% if (error) { %><p class="err"><%= error %></p><% } %>
    <form method="POST" action="/admin/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="email"    name="email"    placeholder="Admin email"    required>
      <input type="password" name="password" placeholder="Password"       required>
      <button type="submit">Login</button>
    </form>
  </div>
</body></html>