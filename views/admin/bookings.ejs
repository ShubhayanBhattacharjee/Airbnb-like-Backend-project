<!DOCTYPE html>
<html>
<head>
  <title>Manage Bookings</title>
  <link rel="stylesheet" href="/css/admin/admin.css">
</head>
<body>
  <nav class="sidebar">
    <h1><span>●</span> Ops Console</h1>
    <a href="/admin/dashboard">Dashboard</a>
    <a href="/admin/users">Users</a>
    <a href="/admin/listings">Listings</a>
    <a href="/admin/bookings" class="active">Bookings</a>
    <a href="/admin/payouts">Payouts</a>
    <a href="/admin/reviews">Reviews</a>
    <a href="/admin/issues">Issues</a>
    <a href="/admin/auditLog">Audit Log</a>
    <form method="POST" action="/admin/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button>Sign out</button>
    </form>
  </nav>

  <div class="main">
    <div class="status-strip">
      <span class="pulse-dot"></span>
      <span>Live</span>
      <span class="dim">·</span>
      <span><%= new Date().toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
    </div>
    <h2>Manage Bookings</h2>

    <form method="GET" class="filter-bar">
      <select name="status">
        <option value="all"       <%= filters.status === 'all'       ? 'selected' : '' %>>All statuses</option>
        <option value="upcoming"  <%= filters.status === 'upcoming'  ? 'selected' : '' %>>Upcoming</option>
        <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
        <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
      </select>
      <button type="submit" class="btn-export-primary">Filter</button>
    </form>

    <p class="result-count"><strong><%= total %></strong> booking(s) found</p>

    <table class="admin-table">
      <thead>
        <tr>
          <th>Guest</th>
          <th>Home</th>
          <th>Check-in</th>
          <th>Check-out</th>
          <th>Nights</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Payment</th>
        </tr>
      </thead>
      <tbody>
        <% bookings.forEach(b => { %>
        <tr>
          <td>
            <%= b.guest?.fname %> <%= b.guest?.lname %>
            <span class="reason-note"><%= b.guest?.email %></span>
          </td>
          <td>
            <%= b.home?.houseName %>
            <span class="reason-note"><%= b.home?.location %></span>
          </td>
          <td class="num"><%= new Date(b.checkIn).toLocaleDateString('en-IN') %></td>
          <td class="num"><%= new Date(b.checkOut).toLocaleDateString('en-IN') %></td>
          <td class="num"><%= b.nights %></td>
          <td class="num">₹<%= b.totalPrice.toLocaleString('en-IN') %></td>
          <td><span class="badge badge-<%= b.status %>"><%= b.status %></span></td>
          <td><span class="badge badge-<%= b.paymentStatus %>"><%= b.paymentStatus %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %>
          <a href="/admin/bookings?page=<%= page - 1 %>&status=<%= filters.status %>">← Prev</a>
        <% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="/admin/bookings?page=<%= i %>&status=<%= filters.status %>"
            class="<%= i === page ? 'active' : '' %>"><%= i %></a>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="/admin/bookings?page=<%= page + 1 %>&status=<%= filters.status %>">Next →</a>
        <% } %>
      </div>
      <p style="font-size:12.5px;color:var(--text-faint);margin-top:8px;">Page <%= page %> of <%= totalPages %></p>
    <% } %>
  </div>
</body>
</html>