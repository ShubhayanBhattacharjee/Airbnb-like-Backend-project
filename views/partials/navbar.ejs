            <circle cx="68" cy="18" r="3" fill="#FF6A1A"/>
            <text x="86" y="42" font-family="Space Grotesk, sans-serif" font-size="34" font-weight="700"
                fill="currentColor" letter-spacing="0.5">roovia</text>
        </svg>
    </a>
    <ul class="nav-links">
      <li><a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a></li>
      <li><a href="/hosts" class="<%= currentPath === '/hosts' ? 'active' : '' %>">Hosts</a></li>
      <li><a href="/about" class="<%= currentPath === '/about' ? 'active' : '' %>">About</a></li>
      <li><a href="/contact" class="<%= currentPath === '/contact' ? 'active' : '' %>">Contact</a></li>
    </ul>
    <div class="nav-actions">
      <a href="/homeList" class="nav-icon-btn" aria-label="Explore homes">
          <svg viewBox="0 0 24 24" fill="none">
              <circle cx="11" cy="11" r="7"
                  stroke="currentColor"
                  stroke-width="1.8"/>
              <path d="M20 20L17 17"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"/>
          </svg>
      </a>
      <% if (!isLoggedIn) { %>
        <a href="/signup" class="btn primary">Join Roovia</a>
      <% } else { %>
        <div class="profile-menu" id="profileMenu">
          <button type="button" class="nav-profile-btn" id="profileTrigger" aria-haspopup="true" aria-expanded="false">
            <span class="nav-profile-avatar">
                <% if (user.profileImage) { %>
                    <img
                        src="<%= user.profileImage %>"
                        alt="Profile"
                        class="profile-avatar-img">
                <% } else { %>
                    <%= user.fname.charAt(0).toUpperCase() %>
                <% } %>
            </span>
            <span class="nav-profile-name">
                <%= user.fname %>
            </span>
            <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="profile-dropdown" id="profileDropdown" role="menu">
            <% if (user && user.role === 'guest') { %>
              <a href="/bookings" class="dropdown-item" role="menuitem">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3.5" y="5" width="17" height="16" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M8 3.5v4M16 3.5v4M3.5 10h17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                Bookings
              </a>
              <a href="/favourites" class="dropdown-item" role="menuitem">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20.5s-7.6-4.7-10-9.3C.5 8 1.8 4.8 5 3.8c2-.6 4 .1 5.2 1.9L12 8l1.8-2.3c1.2-1.8 3.2-2.5 5.2-1.9 3.2 1 4.5 4.2 3 7.4-2.4 4.6-10 9.3-10 9.3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                Favourites
              </a>
              <a href="/profile" class="dropdown-item" role="menuitem">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.6"/><path d="M19.4 13.5a1.7 1.7 0 0 0 .3 1.9l.1.1a2 2 0 1 1-2.9 2.9l-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.6v.2a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1.1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1a2 2 0 1 1-2.9-2.9l.1-.1a1.7 1.7 0 0 0 .3-1.9 1.7 1.7 0 0 0-1.6-1H2.5a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.6-1 1.7 1.7 0 0 0-.3-1.9l-.1-.1a2 2 0 1 1 2.9-2.9l.1.1a1.7 1.7 0 0 0 1.9.3H8.8a1.7 1.7 0 0 0 1-1.6V2.5a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.6 1.7 1.7 0 0 0 1.9-.3l.1-.1a2 2 0 1 1 2.9 2.9l-.1.1a1.7 1.7 0 0 0-.3 1.9v.1a1.7 1.7 0 0 0 1.6 1h.2a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.6 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
                Account settings
              </a>
              <form action="/logout" method="POST" class="logout-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="dropdown-item logout-item">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M16 17L21 12L16 7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M21 12H9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                        <path d="M13 21H5C3.9 21 3 20.1 3 19V5C3 3.9 3.9 3 5 3H13" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Logout
                </button>
            </form>
            <% } else if (user && user.role === 'host') { %>
              <a href="/host/addHome" class="dropdown-item" role="menuitem">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 11.5 12 4l8 7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 10v9.5a1 1 0 0 0 1 1h3.5V16h3v4.5H17a1 1 0 0 0 1-1V10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M9.8 8.2h4.4M12 6v4.4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                Add home
              </a>
              <a href="/host/hostHomeList" class="dropdown-item" role="menuitem">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3.5" y="4" width="17" height="4.5" rx="1.2" stroke="currentColor" stroke-width="1.6"/><rect x="3.5" y="10.2" width="17" height="4.5" rx="1.2" stroke="currentColor" stroke-width="1.6"/><rect x="3.5" y="16.4" width="17" height="4.5" rx="1.2" stroke="currentColor" stroke-width="1.6"/></svg>
                My Listings
              </a>
              <a href="/host/dashboard" class="dropdown-item" role="menuitem">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3.5" y="3.5" width="7.5" height="7.5" rx="1.3" stroke="currentColor" stroke-width="1.6"/><rect x="13" y="3.5" width="7.5" height="7.5" rx="1.3" stroke="currentColor" stroke-width="1.6"/><rect x="3.5" y="13" width="7.5" height="7.5" rx="1.3" stroke="currentColor" stroke-width="1.6"/><rect x="13" y="13" width="7.5" height="7.5" rx="1.3" stroke="currentColor" stroke-width="1.6"/></svg>
                Dashboard
              </a>
              <a href="/profile" class="dropdown-item" role="menuitem">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.6"/><path d="M19.4 13.5a1.7 1.7 0 0 0 .3 1.9l.1.1a2 2 0 1 1-2.9 2.9l-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.6v.2a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1.1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1a2 2 0 1 1-2.9-2.9l.1-.1a1.7 1.7 0 0 0 .3-1.9 1.7 1.7 0 0 0-1.6-1H2.5a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.6-1 1.7 1.7 0 0 0-.3-1.9l-.1-.1a2 2 0 1 1 2.9-2.9l.1.1a1.7 1.7 0 0 0 1.9.3H8.8a1.7 1.7 0 0 0 1-1.6V2.5a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.6 1.7 1.7 0 0 0 1.9-.3l.1-.1a2 2 0 1 1 2.9 2.9l-.1.1a1.7 1.7 0 0 0-.3 1.9v.1a1.7 1.7 0 0 0 1.6 1h.2a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.6 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
                Account settings
              </a>
              <form action="/logout" method="POST" class="logout-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="dropdown-item logout-item">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M16 17L21 12L16 7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M21 12H9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                        <path d="M13 21H5C3.9 21 3 20.1 3 19V5C3 3.9 3.9 3 5 3H13" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Logout
                </button>
            </form>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <ul class="mobile-nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/hosts">Hosts</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/contact">Contact</a></li>
  <% if (isLoggedIn) { %>
    <li class="mobile-profile">
        <button class="mobile-profile-trigger" id="mobileProfileTrigger" type="button" aria-expanded="false"><span>Profile</span>
            <svg class="mobile-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
        <div class="mobile-profile-dropdown" id="mobileProfileDropdown">
            <% if(user.role==="guest"){ %>
              <a href="/bookings">Bookings</a>
              <a href="/favourites">Favourites</a>
              <a href="/profile">Account Settings</a>
            <% } else { %>
              <a href="/host/addHome">Add Home</a>
              <a href="/host/hostHomeList">My Listings</a>
              <a href="/host/dashboard">Dashboard</a>
              <a href="/profile">Account Settings</a>
            <% } %>
        </div>
    </li>
  <% } %>
  </ul>
  <div class="mobile-nav-actions">
   <a href="/homeList" class="btn ghost">Search</a> 
    <% if (!isLoggedIn) { %>
      <a href="/signup" class="btn primary">Join Roovia</a>
    <% } else { %>
      <form action="/logout" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn primary">Logout</button>
      </form>
    <% } %>
  </div>
</div>
<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  const navbar = document.getElementById('navbar');

  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', isOpen);
  });
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      hamburger.classList.remove('open');
      mobileMenu.classList.remove('open');
      hamburger.setAttribute('aria-expanded', false);
    });
  });
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 8);
  }, { passive: true });
  const profileMenu = document.getElementById('profileMenu');
  if (profileMenu) {
    const profileTrigger = document.getElementById('profileTrigger');
    const profileDropdown = document.getElementById('profileDropdown');
    const closeDropdown = () => {
      profileMenu.classList.remove('open');
      profileTrigger.setAttribute('aria-expanded', 'false');
    };
    profileTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = profileMenu.classList.toggle('open');
      profileTrigger.setAttribute('aria-expanded', isOpen);
    });
    document.addEventListener('click', (e) => {
      if (!profileMenu.contains(e.target)) closeDropdown();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDropdown();
    });
    profileDropdown.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeDropdown);
    });
  }
  const mobileProfile = document.querySelector(".mobile-profile");
  if (mobileProfile) {
      const trigger = document.getElementById("mobileProfileTrigger");
      trigger.addEventListener("click", () => {
          const isOpen = mobileProfile.classList.toggle("open");
          trigger.setAttribute("aria-expanded", isOpen);
     });
  }
</script>