<%- include("partials/header", { pageTitle: "404 · Not Found" }) %>
<link rel="stylesheet" href="/css/404.css">
</head>
<body>
  <div class="notfound-wrap">
    <div class="notfound-box">
      <div class="status-strip">
        <span class="pulse-dot-bad"></span>
        SYSTEM <span class="dim">/</span> ROUTE CHECK
      </div>

      <div class="notfound-code">4<span>0</span>4</div>
      <h2>This route doesn't exist</h2>
      <p>The page you requested couldn't be matched to anything on the server. It may have been moved, renamed, or never existed.</p>

      <div class="notfound-readout">
        <div class="readout-row">
          <span class="k">Requested</span>
          <span class="v"><%= typeof path !== 'undefined' ? path : '/unknown' %></span>
        </div>
        <div class="readout-row">
          <span class="k">Status</span>
          <span class="badge badge-failed">Not Found</span>
        </div>
        <div class="readout-row">
          <span class="k">Reason</span>
          <span class="v">No matching route</span>
        </div>
      </div>

      <div class="notfound-actions">
        <a href="/" class="btn-primary">Return home</a>
      </div>
    </div>
  </div>
</body>
</html>