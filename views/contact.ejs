<%- include("partials/header", { pageTitle: "Contact" }) %>
<link rel="stylesheet" href="/css/contact.css">
</head>
    <body class="contact-body">
    <%- include('partials/navbar') %>
    <section class="contact-hero">
        <div class="contact-image">
            <img src="/images/contact-bg.png" alt="Luxury Contact">
        </div>
        <div class="contact-overlay"></div>
        <div class="contact-container">
            <div class="contact-content">
                <p class="small-tag">
                    WE’D LOVE TO HEAR FROM YOU
                </p>
                <h1>
                    Let’s stay
                    <span>connected.</span>
                </h1>
                <p class="contact-text">
                    Have a question, a suggestion, or simply want to say hello?
                    We’re here to help and always happy to connect with you.
                </p>
                <div class="contact-features">
                    <div class="feature-item">
                        <div class="feature-icon">✉</div>
                        <div>
                            <h4>Email us</h4>
                            <p>hello@homestays.com</p>
                        </div>
                    </div>
                    <div class="feature-divider"></div>
                    <div class="feature-item">
                        <div class="feature-icon">☏</div>
                        <div>
                            <h4>Call directly</h4>
                            <p>+91 98765 43210</p>
                        </div>
                    </div>
                    <div class="feature-divider"></div>
                    <div class="feature-item">
                        <div class="feature-icon">⌂</div>
                        <div>
                            <h4>Visit us</h4>
                            <p>Kolkata, West Bengal</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <%- include('partials/footer') %>
    </body>
</html>