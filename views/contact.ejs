<%- include("partials/header", { pageTitle: "Contact" }) %>
<link rel="stylesheet" href="/css/contact.css">
</head>
<body class="contact-body">
<%- include('partials/navbar') %>

<section class="contact-hero">
    <div class="contact-container">
        <div class="contact-content">
            <p class="small-tag">
                WE’D LOVE TO HEAR FROM YOU
            </p>
            <h1>
                Let’s stay
                <span>connected.</span>
            </h1>
            <p class="contact-text">
                Have a question, a suggestion, or simply want to say hello?
                We’re here to help and always happy to connect with you.
            </p>
            <div class="contact-features">
                <div class="feature-item">
                    <div class="feature-icon">✉</div>
                    <div>
                        <h4>Email us</h4>
                        <p>hello@homestays.com</p>
                    </div>
                </div>
                <div class="feature-divider"></div>
                <div class="feature-item">
                    <div class="feature-icon">☏</div>
                    <div>
                        <h4>Call directly</h4>
                        <p>+91 98765 43210</p>
                    </div>
                </div>
                <div class="feature-divider"></div>
                <div class="feature-item">
                    <div class="feature-icon">⌂</div>
                    <div>
                        <h4>Visit us</h4>
                        <p>Kolkata, West Bengal</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="support-section">
    <div class="support-grid">

        <div class="support-info">
            <div class="status-strip">
                <span class="pulse-dot-good"></span>
                Support team online
            </div>
            <h2>Need help with something?</h2>
            <p>
                Booking trouble, a payment that didn’t go through, or a listing
                that looks off — tell us what’s wrong and our team will pick it
                up personally. No bots, no runaround.
            </p>

            <div class="support-stats">
                <div class="support-stat">
                    <div class="support-stat-num">&lt; 24h</div>
                    <div class="support-stat-label">Avg. response time</div>
                </div>
                <div class="support-stat">
                    <div class="support-stat-num">7 / 7</div>
                    <div class="support-stat-label">Days a week</div>
                </div>
                <div class="support-stat">
                    <div class="support-stat-num">2</div>
                    <div class="support-stat-label">Languages (EN / HI)</div>
                </div>
                <div class="support-stat">
                    <div class="support-stat-num">100%</div>
                    <div class="support-stat-label">Human replies</div>
                </div>
            </div>
        </div>

        <div class="support-form-panel">
            <h3>Report an issue</h3>
            <p class="form-sub">Fill in the details below and we’ll get back to you shortly.</p>

            <form action="/contact/support" method="POST">
                <div class="form-row">
                    <div class="form-group">
                        <label for="name">Full name</label>
                        <input type="text" id="name" name="name" placeholder="Your name" required>
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" placeholder="you@example.com" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="booking_id">Booking ID <span style="font-weight:400;text-transform:none;">(optional)</span></label>
                        <input type="text" id="booking_id" name="booking_id" placeholder="e.g. HS-10432">
                    </div>
                    <div class="form-group">
                        <label for="issue_type">Issue type</label>
                        <select id="issue_type" name="issue_type" required>
                            <option value="" disabled selected>Select an issue</option>
                            <option value="booking">Booking issue</option>
                            <option value="payment">Payment / refund</option>
                            <option value="account">Account access</option>
                            <option value="listing">Property listing</option>
                            <option value="other">Something else</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label for="subject">Subject</label>
                    <input type="text" id="subject" name="subject" placeholder="Briefly summarise the issue" required>
                </div>

                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" placeholder="Tell us what happened, including any relevant dates or details." required></textarea>
                </div>

                <div class="form-note">
                    <span class="badge-sla">24H SLA</span>
                    Our support team will get back to you within 24 hours.
                </div>

                <button type="submit" class="btn-primary">Send message</button>
            </form>
        </div>

    </div>
</section>

<%- include('partials/footer') %>
</body>
</html>