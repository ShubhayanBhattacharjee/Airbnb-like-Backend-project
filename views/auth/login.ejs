<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/login.css">
</head>

<body class="login-body">
<%- include('../partials/navbar') %>

<div class="login-container">

  <!-- LEFT PANEL -->
  <div class="login-left"></div>

  <!-- RIGHT PANEL -->
  <div class="login-right">

    <a href="/" class="back-link">← back to home</a>

    <div class="form-box">
      <h2>Welcome Back</h2>
      <p class="subtitle">Sign in to continue your journey</p>

      <% if(typeof errors!="undefined" && errors.length>0) { %>
        <div class="error-alert">
          <ul>
            <% errors.forEach(function(error) { %>
              <li><%= error %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form action="/login" method="POST">

        <label>Email address</label>
        <input type="email" name="email" placeholder="youremail@example.com"
          value="<%= typeof oldInput !== 'undefined' && oldInput.email ? oldInput.email : '' %>" required>

        <label>Password</label>
        <input type="password" name="password" placeholder="enter your password" required>

        <button type="submit" class="btn-login">sign in</button>

      </form>

      <div class="divider">or continue with</div>

      <button class="social-btn">continue with google</button>
      <button class="social-btn">continue with apple</button>

      <p class="bottom-text">
        don’t have an account? <a href="/register">get started</a>
      </p>
    </div>

  </div>

</div>

</body>
</html>