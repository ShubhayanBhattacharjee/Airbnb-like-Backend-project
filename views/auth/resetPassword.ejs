<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/auth/login.css">
</head>
<body class="login-body">
  <section class="login-section">
    <div class="login-wrapper">
      <div class="login-content">
        <p class="small-tag">Account Recovery</p>
        <h1>Set a new <span>password.</span></h1>
        <p class="login-text">
          Choose something you haven't used before. Once saved, you can sign back in right away.
        </p>
      </div>
      <div class="form-box">
        <% if (typeof errors !== "undefined" && errors.length > 0) { %>
          <div class="error-alert">
            <ul>
              <% errors.forEach(function(e) { %>
                <li><%= e %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>
        <form action="/reset-password" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="input-group">
  <label for="password">New password</label>
  <div class="password-field">
    <input type="password" id="password" name="password" placeholder="Create new password" required>
    <button type="button" class="pw-toggle" aria-label="Show password">
      <svg class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
      </svg>
      <svg class="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
        <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20c-7 0-11-8-11-8a18.5 18.5 0 0 1 5.06-5.94M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
        <line x1="1" y1="1" x2="23" y2="23"/>
      </svg>
    </button>
  </div>
</div>

<div class="input-group">
  <label for="Cpassword">Confirm password</label>
        <div class="password-field">
            <input type="password" id="Cpassword" name="Cpassword" placeholder="Repeat new password" required>
            <button type="button" class="pw-toggle" aria-label="Show password">
            <svg class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
            </svg>
            <svg class="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20c-7 0-11-8-11-8a18.5 18.5 0 0 1 5.06-5.94M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
            </button>
        </div>
        </div>
          <button type="submit" class="btn-login">Update Password</button>
        </form>
        <p class="bottom-text">
          Changed your mind?
          <a href="/login">Back to login</a>
        </p>
      </div>
    </div>
  </section>
  <script src="/js/passwordToggle.js"></script>
</body>
</html>