<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/signup.css">
</head>
  <body class="signup-body">
  <%- include('../partials/navbar') %>
  <section class="signup-section">
    <div class="signup-wrapper">
      <div class="signup-content">
        <p class="small-tag">
          BEGIN YOUR JOURNEY
        </p>
        <h1>
          Create your <span>account.</span>
        </h1>
        <p class="signup-text">
          Join a world of thoughtfully curated stays,
          calm escapes, and meaningful experiences designed around slower living.
        </p>
      </div>
      <div class="form-box">
        <% if(typeof errors!="undefined" && errors.length>0) { %>
          <div class="error-alert">
            <ul>
              <% errors.forEach(function(error) { %>
                <li><%= error %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>
        <form action="/signup" method="POST" enctype="multipart/form-data">
          <div class="input-group">
            <label>First name</label>
            <input
              type="text"
              name="fname"
              placeholder="John"
              value="<%= typeof oldInput !== 'undefined' ? oldInput.fname : '' %>"
              required
            >
          </div>
          <div class="input-group">
            <label>Last name</label>
            <input
              type="text"
              name="lname"
              placeholder="Doe"
              value="<%= typeof oldInput !== 'undefined' ? oldInput.lname : '' %>"
              required
            >
          </div>
          <div class="input-group">
            <label>Middle name</label>
            <input
              type="text"
              name="mname"
              placeholder="Optional"
              value="<%= typeof oldInput !== 'undefined' ? oldInput.mname : '' %>"
            >
          </div>
          <div class="input-group">
            <label>Email</label>
            <input
              type="email"
              name="email"
              placeholder="you@example.com"
              value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>"
              required
            >
          </div>
          <div class="input-group">
            <label>Password</label>
            <input
              type="password"
              name="password"
              placeholder="Create password"
              required
            >
          </div>
          <div class="input-group">
            <label>Confirm</label>
            <input
              type="password"
              name="Cpassword"
              placeholder="Confirm password"
              required
            >
          </div>
          <div class="input-group">
            <label>Role</label>
            <select name="role" required>
              <option value="" disabled selected>Select role</option>
              <option value="guest">Guest</option>
              <option value="host">Host</option>
            </select>
          </div>
          <div class="input-group">
            <label>Profile Image</label>
            <input
              type="file"
              name="photo"
              accept="image/png,image/jpg,image/jpeg"
            >
          </div>
          <div class="input-group">
            <label>Location</label>
            <input
              type="text"
              name="location"
              placeholder="Spiti Valley"
            >
          </div>
          <div class="input-group">
            <label>Country</label>
            <input
              type="text"
              name="country"
              placeholder="India"
            >
          </div>
          <div class="input-group">
            <label>Phone</label>
            <input
              type="text"
              name="phone"
              placeholder="+91 9876543210"
            >
          </div>
          <div class="input-group">
            <label>Bio</label>
            <textarea
              name="bio"
              rows="4"
              placeholder="Tell us something about yourself..."
            ></textarea>
          </div>
          <label class="checkbox-row">
            <input
              type="checkbox"
              name="terms"
              value="accepted"
              required
            >
            <span>
              I agree to the Terms & Conditions
            </span>
          </label>
          <button type="submit" class="btn-signup">
            Create Account
          </button>
        </form>
        <div class="divider">
          <span>or continue with</span>
        </div>
        <div class="social-buttons">
          <button class="social-btn">
            Google
          </button>
          <button class="social-btn">
            Apple
          </button>
        </div>
        <p class="bottom-text">
          Already have an account?
          <a href="/login">Sign in</a>
        </p>
      </div>
    </div>
  </section>
  <%- include('../partials/footer') %>
  </body>
</html>