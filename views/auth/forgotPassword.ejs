<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/auth/login.css">
</head>
<body class="login-body">
  <section class="login-section">
    <div class="login-wrapper">
      <div class="login-content">
        <p class="small-tag">Account Recovery</p>
        <h1>Forgot your <span>password?</span></h1>
        <p class="login-text">
          Enter the email tied to your account and we'll send you a 6-digit code to get back in.
        </p>
      </div>
      <div class="form-box">
        <% if (message) { %>
          <div class="error-alert" style="background: rgba(111,207,151,.13); border-color: rgba(111,207,151,.25);">
            <ul><li style="color:#6FCF97;"><%= message %></li></ul>
          </div>
        <% } %>
        <% if (typeof errors !== "undefined" && errors.length > 0) { %>
          <div class="error-alert">
            <ul>
              <% errors.forEach(function(e) { %>
                <li><%= e %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>
        <form action="/forgot-password" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="input-group">
            <label for="email">Email address</label>
            <input type="email" id="email" name="email" placeholder="youremail@example.com" required>
          </div>
          <button type="submit" class="btn-login">Send Code</button>
        </form>
        <p class="bottom-text">
          Remembered it after all?
          <a href="/login">Back to login</a>
        </p>
      </div>
    </div>
  </section>
</body>
</html>